<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
		xmlns:android="http://schemas.android.com/apk/res/android"
		xmlns:app="http://schemas.android.com/apk/res-auto"
		xmlns:tools="http://schemas.android.com/tools"
		android:id="@+id/main"
		android:layout_width="match_parent"
		android:layout_height="match_parent"
		android:background="@android:color/white"
		tools:context=".Views.Productos.MainProductosActivity">

	<TextView
			android:id="@+id/textViewTitulo"
			android:layout_width="wrap_content"
			android:layout_height="wrap_content"
			android:layout_marginTop="24dp"
			android:fontFamily="sans-serif-condensed"
			android:text="Gestionar Productos"
			android:textSize="26sp"
			android:textStyle="bold"
			app:layout_constraintEnd_toEndOf="parent"
			app:layout_constraintStart_toStartOf="parent"
			app:layout_constraintTop_toTopOf="parent" />

	<View
			android:id="@+id/divider"
			android:layout_width="match_parent"
			android:layout_height="2dp"
			android:layout_marginTop="8dp"
			android:layout_marginHorizontal="24dp"
			android:background="#EEEEEE"
			app:layout_constraintTop_toBottomOf="@+id/textViewTitulo" />

	<Button
			android:id="@+id/btnGestionarCatalogos"
			style="@style/Widget.MaterialComponents.Button.OutlinedButton"
			android:layout_width="0dp"
			android:layout_height="60dp"
			android:layout_marginStart="24dp"
			android:layout_marginTop="32dp"
			android:layout_marginEnd="24dp"
			android:elevation="2dp"
			android:fontFamily="sans-serif"
			android:letterSpacing="0.02"
			android:minHeight="60dp"
			android:paddingVertical="12dp"
			android:text="Gestionar Catalogos"
			android:textAllCaps="false"
			android:textSize="16sp"
			android:textStyle="bold"
			app:cornerRadius="12dp"
			app:layout_constraintEnd_toEndOf="parent"
			app:layout_constraintStart_toStartOf="parent"
			app:layout_constraintTop_toBottomOf="@+id/divider"
			android:onClick="catalogoMenu"/>

	<Button
			android:id="@+id/btnEmpleado"
			style="@style/Widget.MaterialComponents.Button.OutlinedButton"
			android:layout_width="0dp"
			android:layout_height="60dp"
			android:layout_marginStart="24dp"
			android:layout_marginTop="16dp"
			android:layout_marginEnd="24dp"
			android:elevation="2dp"
			android:fontFamily="sans-serif"
			android:letterSpacing="0.02"
			android:minHeight="60dp"
			android:paddingVertical="12dp"
			android:text="Gestionar Categorias"
			android:textAllCaps="false"
			android:textSize="16sp"
			android:textStyle="bold"
			android:onClick="categoriaMenu"
			app:cornerRadius="12dp"
			app:layout_constraintEnd_toEndOf="parent"
			app:layout_constraintStart_toStartOf="parent"
			app:layout_constraintTop_toBottomOf="@+id/btnGestionarCatalogos" />

	<Button
			android:id="@+id/btnHistorialPrecio"
			style="@style/Widget.MaterialComponents.Button.OutlinedButton"
			android:layout_width="0dp"
			android:layout_height="60dp"
			android:layout_marginStart="24dp"
			android:layout_marginTop="16dp"
			android:layout_marginEnd="24dp"
			android:elevation="2dp"
			android:fontFamily="sans-serif"
			android:letterSpacing="0.02"
			android:minHeight="60dp"
			android:paddingVertical="12dp"
			android:text="Gestionar Historial Precio"
			android:textAllCaps="false"
			android:textSize="16sp"
			android:textStyle="bold"
			app:cornerRadius="12dp"
			app:layout_constraintEnd_toEndOf="parent"
			app:layout_constraintStart_toStartOf="parent"
			app:layout_constraintTop_toBottomOf="@+id/btnEmpleado"
			android:onClick="historialMenu"/>

	<Button
			android:id="@+id/btnInventario"
			style="@style/Widget.MaterialComponents.Button.OutlinedButton"
			android:layout_width="0dp"
			android:layout_height="60dp"
			android:layout_marginStart="24dp"
			android:layout_marginTop="16dp"
			android:layout_marginEnd="24dp"
			android:elevation="2dp"
			android:fontFamily="sans-serif"
			android:letterSpacing="0.02"
			android:minHeight="60dp"
			android:paddingVertical="12dp"
			android:text="Gestionar Inventario"
			android:textAllCaps="false"
			android:textSize="16sp"
			android:textStyle="bold"
			app:cornerRadius="12dp"
			app:layout_constraintEnd_toEndOf="parent"
			app:layout_constraintStart_toStartOf="parent"
			app:layout_constraintTop_toBottomOf="@+id/btnHistorialPrecio"
			android:onClick="inventarioMenu"/>

	<Button
			android:id="@+id/btnMovimientos"
			style="@style/Widget.MaterialComponents.Button.OutlinedButton"
			android:layout_width="0dp"
			android:layout_height="60dp"
			android:layout_marginStart="24dp"
			android:layout_marginTop="16dp"
			android:layout_marginEnd="24dp"
			android:elevation="2dp"
			android:fontFamily="sans-serif"
			android:letterSpacing="0.02"
			android:minHeight="60dp"
			android:paddingVertical="12dp"
			android:text="Gestionar Movimientos"
			android:textAllCaps="false"
			android:textSize="16sp"
			android:textStyle="bold"
			app:cornerRadius="12dp"
			app:layout_constraintEnd_toEndOf="parent"
			app:layout_constraintStart_toStartOf="parent"
			app:layout_constraintTop_toBottomOf="@+id/btnInventario"
			android:onClick="movimientoMenu"/>

	<Button
			android:id="@+id/btnProductos"
			style="@style/Widget.MaterialComponents.Button.OutlinedButton"
			android:layout_width="0dp"
			android:layout_height="60dp"
			android:layout_marginStart="24dp"
			android:layout_marginTop="16dp"
			android:layout_marginEnd="24dp"
			android:layout_marginBottom="24dp"
			android:elevation="2dp"
			android:fontFamily="sans-serif"
			android:letterSpacing="0.02"
			android:minHeight="60dp"
			android:paddingVertical="12dp"
			android:text="Gestionar Productos"
			android:textAllCaps="false"
			android:textSize="16sp"
			android:textStyle="bold"
			android:onClick="productoMenu"
			app:cornerRadius="12dp"
			app:layout_constraintBottom_toBottomOf="parent"
			app:layout_constraintEnd_toEndOf="parent"
			app:layout_constraintStart_toStartOf="parent"
			app:layout_constraintTop_toBottomOf="@+id/btnMovimientos"
			app:layout_constraintHorizontal_bias="1.0"
			app:layout_constraintVertical_bias="0.024"/>

</androidx.constraintlayout.widget.ConstraintLayout>