<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
		xmlns:android="http://schemas.android.com/apk/res/android"
		xmlns:tools="http://schemas.android.com/tools"
		xmlns:app="http://schemas.android.com/apk/res-auto"
		android:id="@+id/main"
		android:layout_width="match_parent"
		android:layout_height="match_parent"
		tools:context=".Views.Pedidos.FacturasActivity">

	<TextView
			android:id="@+id/textViewTitulo"
			android:layout_width="wrap_content"
			android:layout_height="wrap_content"
			android:text="Formulario Facturas"
			app:layout_constraintTop_toTopOf="parent"
			app:layout_constraintStart_toStartOf="parent"
			app:layout_constraintEnd_toEndOf="parent"
			app:layout_constraintVertical_bias="0.008"
			app:layout_constraintBottom_toBottomOf="parent"/>

	<EditText
			android:id="@+id/fechaFactura"
			android:layout_width="0dp"
			android:layout_height="wrap_content"
			android:hint="Fecha de Emisión"
			android:inputType="date"
			app:layout_constraintStart_toStartOf="parent"
			app:layout_constraintEnd_toEndOf="parent"
			app:layout_constraintTop_toTopOf="@+id/textViewTitulo"
			app:layout_constraintBottom_toBottomOf="parent"
			app:layout_constraintVertical_bias="0.15" />

	<EditText
			android:id="@+id/horaFactura"
			android:layout_width="0dp"
			android:layout_height="wrap_content"
			android:hint="Hora de creacion"
			android:inputType="text"
			app:layout_constraintStart_toStartOf="parent"
			app:layout_constraintEnd_toEndOf="parent"
			app:layout_constraintTop_toTopOf="@+id/textViewTitulo"
			app:layout_constraintBottom_toBottomOf="parent"
			app:layout_constraintVertical_bias="0.232" />

	<Button
			android:id="@+id/crearFactura"
			android:text="Crear Factura"
			android:layout_width="159dp"
			android:layout_height="47dp"
			android:onClick="crearFactura"
			app:layout_constraintStart_toStartOf="parent"
			app:layout_constraintEnd_toEndOf="parent"
			app:layout_constraintHorizontal_bias="0.13"
			app:layout_constraintTop_toTopOf="parent"
			app:layout_constraintBottom_toBottomOf="parent"
			app:layout_constraintVertical_bias="0.402" />

	<Button
			android:id="@+id/listarFacturas"
			android:text="Listar Facturas"
			android:layout_width="159dp"
			android:layout_height="47dp"
			android:onClick="listarFacturas"
			app:layout_constraintStart_toStartOf="parent"
			app:layout_constraintTop_toTopOf="parent"
			app:layout_constraintBottom_toBottomOf="parent"
			app:layout_constraintEnd_toEndOf="parent"
			app:layout_constraintHorizontal_bias="0.869"
			app:layout_constraintVertical_bias="0.402" />

	<TextView
			android:id="@+id/textViewListado"
			android:text="Visualización de las facturas"
			android:layout_width="wrap_content"
			android:layout_height="wrap_content"
			app:layout_constraintStart_toStartOf="parent"
			app:layout_constraintEnd_toEndOf="parent"
			android:layout_marginTop="8dp"
			app:layout_constraintBottom_toBottomOf="parent"
			app:layout_constraintVertical_bias="0.583"
			app:layout_constraintTop_toTopOf="parent"/>

	<ScrollView
			android:layout_width="0dp"
			android:layout_height="0dp"
			app:layout_constraintTop_toBottomOf="@id/textViewListado"
			app:layout_constraintStart_toStartOf="parent"
			app:layout_constraintEnd_toEndOf="parent"
			app:layout_constraintBottom_toBottomOf="parent"
			android:fillViewport="true">

		<TableLayout
				android:id="@+id/tableFacturas"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:stretchColumns="*"
				android:padding="8dp">

			<TableRow
					android:layout_width="wrap_content"
					android:layout_height="54dp"
					android:background="#DDDDDD">

				<TextView
						android:layout_width="0dp"
						android:layout_height="wrap_content"
						android:layout_weight="1"
						android:text="Fecha"
						android:padding="8dp"
						android:textStyle="bold"/>

				<TextView
						android:layout_width="0dp"
						android:layout_height="wrap_content"
						android:layout_weight="1"
						android:text="Hora"
						android:padding="8dp"
						android:textStyle="bold"/>

				<TextView
						android:layout_width="0dp"
						android:layout_height="wrap_content"
						android:layout_weight="1.5"
						android:text="Acciones"
						android:padding="8dp"
						android:textStyle="bold"/>
			</TableRow>
		</TableLayout>
	</ScrollView>

	<androidx.constraintlayout.widget.ConstraintLayout
			android:id="@+id/layoutActualizarFactura"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:padding="16dp"
			android:visibility="gone"
			app:layout_constraintTop_toTopOf="parent"
			app:layout_constraintStart_toStartOf="parent"
			app:layout_constraintEnd_toEndOf="parent"
			android:background="@android:color/white">

		<TextView
				android:id="@+id/textViewTituloDialog"
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:text="Actualizar Factura"
				android:textSize="18sp"
				android:textStyle="bold"
				app:layout_constraintTop_toTopOf="parent"
				app:layout_constraintStart_toStartOf="parent"
				app:layout_constraintEnd_toEndOf="parent" />

		<EditText
				android:id="@+id/editTextFechaFactura"
				android:layout_width="0dp"
				android:layout_height="wrap_content"
				android:hint="Fecha de Factura"
				android:inputType="date"
				app:layout_constraintStart_toStartOf="parent"
				app:layout_constraintEnd_toEndOf="parent"
				app:layout_constraintTop_toBottomOf="@id/textViewTituloDialog"
				android:layout_marginTop="8dp"/>

		<EditText
				android:id="@+id/editTextHoraFactura"
				android:layout_width="0dp"
				android:layout_height="wrap_content"
				android:hint="Fecha de Emisión"
				android:inputType="text"
				app:layout_constraintStart_toStartOf="parent"
				app:layout_constraintEnd_toEndOf="parent"
				app:layout_constraintTop_toBottomOf="@id/editTextFechaFactura"
				android:layout_marginTop="16dp"/>


		<Button
				android:id="@+id/btnActualizarFactura"
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:text="Actualizar"
				android:onClick="actualizarFactura"
				app:layout_constraintTop_toBottomOf="@id/editTextHoraFactura"
				app:layout_constraintStart_toStartOf="parent"
				android:layout_marginTop="20dp"/>

		<Button
				android:id="@+id/btnCancelarActualizar"
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:text="Cancelar"
				app:layout_constraintTop_toBottomOf="@id/editTextHoraFactura"
				app:layout_constraintEnd_toEndOf="parent"
				android:layout_marginTop="20dp"/>
	</androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
