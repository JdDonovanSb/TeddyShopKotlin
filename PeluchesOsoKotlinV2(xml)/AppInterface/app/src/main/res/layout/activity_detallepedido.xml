<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
			android:layout_width="match_parent"
			android:layout_height="match_parent"
			android:padding="16dp"
			android:background="#F5F5F5">

	<LinearLayout
			android:orientation="vertical"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:padding="8dp"
			android:background="@android:color/white"
			android:elevation="4dp"
			android:layout_margin="8dp"
			android:layout_gravity="center"
			android:clipToPadding="false">

		<!-- TÍTULO -->
		<TextView
				android:text="Gestión de Detalles de Pedido"
				android:textStyle="bold"
				android:textSize="18sp"
				android:layout_marginBottom="8dp"
				android:layout_width="wrap_content"
				android:layout_height="wrap_content" />

		<!-- REGISTRO DE DETALLE DE PEDIDO -->
		<TextView
				android:text="Registrar nuevo detalle de pedido"
				android:textStyle="bold"
				android:textSize="16sp"
				android:textColor="#3700B3"
				android:layout_marginBottom="8dp"
				android:layout_width="wrap_content"
				android:layout_height="wrap_content" />

		<EditText
				android:id="@+id/numDetallePedido"
				android:hint="Número de Detalle"
				android:inputType="number"
				android:backgroundTint="#FF6200EE"
				android:layout_marginBottom="8dp"
				android:layout_width="match_parent"
				android:layout_height="wrap_content" />

		<EditText
				android:id="@+id/precioDetallePedido"
				android:hint="Precio del Detalle"
				android:inputType="numberDecimal"
				android:backgroundTint="#FF6200EE"
				android:layout_marginBottom="8dp"
				android:layout_width="match_parent"
				android:layout_height="wrap_content" />

		<EditText
				android:id="@+id/cantidadDetallePedido"
				android:hint="Cantidad del Detalle"
				android:inputType="number"
				android:backgroundTint="#FF6200EE"
				android:layout_marginBottom="8dp"
				android:layout_width="match_parent"
				android:layout_height="wrap_content" />

		<Button
				android:id="@+id/btnCrearDetallePedido"
				android:text="Registrar Detalle de Pedido"
				android:onClick="crearDetallePedido"
				android:backgroundTint="#FF6200EE"
				android:textColor="#FFFFFF"
				android:layout_width="match_parent"
				android:layout_height="wrap_content" />

		<Button
				android:id="@+id/listarDetallesPedido"
				android:text="Listar Detalles de Pedido"
				android:onClick="listarDetallesPedido"
				android:backgroundTint="#3700B3"
				android:textColor="#FFFFFF"
				android:layout_marginTop="8dp"
				android:layout_width="match_parent"
				android:layout_height="wrap_content" />

		<!-- ACTUALIZAR DETALLE DE PEDIDO -->
		<LinearLayout
				android:id="@+id/layoutActualizarDetallePedido"
				android:orientation="vertical"
				android:visibility="gone"
				android:layout_marginTop="16dp"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:background="#EEEEEE"
				android:padding="12dp"
				android:layout_marginBottom="8dp"
				android:elevation="2dp">

			<TextView
					android:text="Actualizar Detalle de Pedido"
					android:textStyle="bold"
					android:textSize="16sp"
					android:layout_marginBottom="8dp"
					android:layout_width="wrap_content"
					android:layout_height="wrap_content" />

			<EditText
					android:id="@+id/editTextActualizarDetalleNum"
					android:hint="Nuevo Número"
					android:backgroundTint="#FF6200EE"
					android:layout_marginBottom="8dp"
					android:layout_width="match_parent"
					android:layout_height="wrap_content" />

			<EditText
					android:id="@+id/editTextActualizarPrecio"
					android:hint="Nuevo Precio"
					android:backgroundTint="#FF6200EE"
					android:layout_marginBottom="8dp"
					android:layout_width="match_parent"
					android:layout_height="wrap_content" />

			<EditText
					android:id="@+id/editTextActualizarCantidad"
					android:hint="Nueva Cantidad"
					android:backgroundTint="#FF6200EE"
					android:layout_marginBottom="8dp"
					android:layout_width="match_parent"
					android:layout_height="wrap_content" />

			<Button
					android:id="@+id/btnActualizarDetallePedido"
					android:text="Actualizar Detalle de Pedido"
					android:onClick="actualizarDetallePedido"
					android:backgroundTint="#FF6200EE"
					android:textColor="#FFFFFF"
					android:layout_width="match_parent"
					android:layout_height="wrap_content" />
		</LinearLayout>

		<!-- LISTADO DE DETALLES DE PEDIDO -->
		<TextView
				android:text="Lista de Detalles de Pedido"
				android:textSize="16sp"
				android:textStyle="bold"
				android:layout_marginTop="8dp"
				android:layout_width="wrap_content"
				android:layout_height="wrap_content" />

		<TableLayout
				android:id="@+id/tableDetallesPedido"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:stretchColumns="*"
				android:layout_marginTop="8dp"
				android:background="#FAFAFA"
				android:padding="8dp"
				android:elevation="1dp">

			<TableRow>
				<TextView
						android:text="Número"
						android:padding="8dp"
						android:textStyle="bold"
						android:textColor="#000000" />

				<TextView
						android:text="Precio"
						android:padding="8dp"
						android:textStyle="bold"
						android:textColor="#000000" />

				<TextView
						android:text="Cantidad"
						android:padding="8dp"
						android:textStyle="bold"
						android:textColor="#000000" />

				<TextView
						android:text="Acciones"
						android:padding="8dp"
						android:textStyle="bold"
						android:textColor="#000000" />
			</TableRow>

		</TableLayout>

	</LinearLayout>
</ScrollView>