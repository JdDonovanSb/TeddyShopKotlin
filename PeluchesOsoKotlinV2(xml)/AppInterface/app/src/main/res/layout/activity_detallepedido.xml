<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
		xmlns:android="http://schemas.android.com/apk/res/android"
		xmlns:tools="http://schemas.android.com/tools"
		xmlns:app="http://schemas.android.com/apk/res-auto"
		android:id="@+id/main"
		android:layout_width="match_parent"
		android:layout_height="match_parent"
		tools:context=".Views.Pedidos.DetallePedidoActivity">

	<TextView
			android:id="@+id/textViewTitulo"
			android:layout_width="wrap_content"
			android:layout_height="wrap_content"
			android:text="Formulario Detalle Pedido"
			app:layout_constraintTop_toTopOf="parent"
			app:layout_constraintStart_toStartOf="parent"
			app:layout_constraintEnd_toEndOf="parent"
			app:layout_constraintVertical_bias="0.008"/>

	<EditText
			android:id="@+id/numDetallePedido"
			android:layout_width="0dp"
			android:layout_height="wrap_content"
			android:hint="Número de detalle de pedido"
			android:inputType="number"
			app:layout_constraintStart_toStartOf="parent"
			app:layout_constraintEnd_toEndOf="parent"
			app:layout_constraintTop_toBottomOf="@id/textViewTitulo"
			app:layout_constraintVertical_bias="0.02"/>

	<EditText
			android:id="@+id/precioDetallePedido"
			android:layout_width="0dp"
			android:layout_height="wrap_content"
			android:hint="Precio del detalle"
			android:inputType="numberDecimal"
			app:layout_constraintStart_toStartOf="parent"
			app:layout_constraintEnd_toEndOf="parent"
			app:layout_constraintTop_toBottomOf="@id/numDetallePedido"
			android:layout_marginTop="8dp"/>

	<EditText
			android:id="@+id/cantidadDetallePedido"
			android:layout_width="0dp"
			android:layout_height="wrap_content"
			android:hint="Cantidad del detalle"
			android:inputType="number"
			app:layout_constraintStart_toStartOf="parent"
			app:layout_constraintEnd_toEndOf="parent"
			app:layout_constraintTop_toBottomOf="@id/precioDetallePedido"
			android:layout_marginTop="8dp"/>

	<Button
			android:id="@+id/crearDetallePedido"
			android:text="Crear"
			android:layout_width="85dp"
			android:layout_height="wrap_content"
			android:onClick="crearDetallePedido"
			app:layout_constraintTop_toBottomOf="@id/cantidadDetallePedido"
			app:layout_constraintStart_toStartOf="parent"
			android:layout_marginTop="8dp"/>

	<Button
			android:id="@+id/listarDetallesPedido"
			android:text="Listar"
			android:layout_width="90dp"
			android:layout_height="wrap_content"
			android:onClick="listarDetallesPedido"
			app:layout_constraintTop_toBottomOf="@id/cantidadDetallePedido"
			app:layout_constraintEnd_toEndOf="parent"
			android:layout_marginTop="8dp"/>

	<TextView
			android:id="@+id/textViewResultados"
			android:text="Visualización de los detalles de pedido"
			android:layout_width="wrap_content"
			android:layout_height="wrap_content"
			app:layout_constraintStart_toStartOf="parent"
			app:layout_constraintEnd_toEndOf="parent"
			app:layout_constraintTop_toBottomOf="@id/listarDetallesPedido"
			android:layout_marginTop="16dp"/>

	<ScrollView
			android:layout_width="0dp"
			android:layout_height="0dp"
			app:layout_constraintTop_toBottomOf="@id/textViewResultados"
			app:layout_constraintStart_toStartOf="parent"
			app:layout_constraintEnd_toEndOf="parent"
			app:layout_constraintBottom_toBottomOf="parent"
			android:fillViewport="true">

		<TableLayout
				android:id="@+id/tableDetallesPedido"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:stretchColumns="*"
				android:padding="8dp">

			<TableRow
					android:layout_width="wrap_content"
					android:layout_height="54dp"
					android:background="#DDDDDD">

				<TextView
						android:layout_width="0dp"
						android:layout_height="wrap_content"
						android:layout_weight="1"
						android:text="Número"
						android:padding="8dp"
						android:textStyle="bold"/>

				<TextView
						android:layout_width="0dp"
						android:layout_height="wrap_content"
						android:layout_weight="1"
						android:text="Precio"
						android:padding="8dp"
						android:textStyle="bold"/>

				<TextView
						android:layout_width="0dp"
						android:layout_height="wrap_content"
						android:layout_weight="1"
						android:text="Cantidad"
						android:padding="8dp"
						android:textStyle="bold"/>

				<TextView
						android:layout_width="0dp"
						android:layout_height="wrap_content"
						android:layout_weight="1.5"
						android:text="Acciones"
						android:padding="8dp"
						android:textStyle="bold"/>
			</TableRow>
		</TableLayout>
	</ScrollView>

	<androidx.constraintlayout.widget.ConstraintLayout
			android:id="@+id/layoutActualizarDetallePedido"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:padding="16dp"
			android:visibility="gone"
			app:layout_constraintTop_toTopOf="parent"
			app:layout_constraintStart_toStartOf="parent"
			app:layout_constraintEnd_toEndOf="parent"
			android:background="@android:color/white">

		<TextView
				android:id="@+id/textViewActualizarTitulo"
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:text="Actualizar Detalle Pedido"
				android:textSize="18sp"
				android:textStyle="bold"
				app:layout_constraintTop_toTopOf="parent"
				app:layout_constraintStart_toStartOf="parent"
				app:layout_constraintEnd_toEndOf="parent" />
		<EditText
				android:id="@+id/editTextActualizarDetalleNum"
				android:layout_width="0dp"
				android:layout_height="wrap_content"
				android:hint="Precio"
				android:inputType="numberDecimal"
				app:layout_constraintStart_toStartOf="parent"
				app:layout_constraintEnd_toEndOf="parent"
				app:layout_constraintTop_toBottomOf="@id/textViewActualizarTitulo"
				android:layout_marginTop="8dp"/>

		<EditText
				android:id="@+id/editTextActualizarPrecio"
				android:layout_width="0dp"
				android:layout_height="wrap_content"
				android:hint="Precio"
				android:inputType="numberDecimal"
				app:layout_constraintStart_toStartOf="parent"
				app:layout_constraintEnd_toEndOf="parent"
				app:layout_constraintTop_toBottomOf="@id/textViewActualizarTitulo"
				android:layout_marginTop="8dp"/>

		<EditText
				android:id="@+id/editTextActualizarCantidad"
				android:layout_width="0dp"
				android:layout_height="wrap_content"
				android:hint="Cantidad"
				android:inputType="number"
				app:layout_constraintStart_toStartOf="parent"
				app:layout_constraintEnd_toEndOf="parent"
				app:layout_constraintTop_toBottomOf="@id/editTextActualizarPrecio"
				android:layout_marginTop="8dp"/>

		<Button
				android:id="@+id/btnActualizarDetalle"
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:text="Actualizar"
				android:onClick="actualizarDetallePedido"
				app:layout_constraintTop_toBottomOf="@id/editTextActualizarCantidad"
				app:layout_constraintStart_toStartOf="parent"
				android:layout_marginTop="16dp"/>

		<Button
				android:id="@+id/btnCancelarDetalle"
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:text="Cancelar"
				app:layout_constraintTop_toBottomOf="@id/editTextActualizarCantidad"
				app:layout_constraintEnd_toEndOf="parent"
				android:layout_marginTop="16dp"/>
	</androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
