<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
			android:layout_width="match_parent"
			android:layout_height="match_parent"
			android:padding="16dp"
			android:background="#F5F5F5">

	<LinearLayout
			android:orientation="vertical"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:padding="8dp"
			android:background="@android:color/white"
			android:elevation="4dp"
			android:layout_margin="8dp"
			android:layout_gravity="center"
			android:clipToPadding="false">

		<!-- TÍTULO -->
		<TextView
				android:text="Gestión de Devoluciones"
				android:textStyle="bold"
				android:textSize="18sp"
				android:layout_marginBottom="8dp"
				android:layout_width="wrap_content"
				android:layout_height="wrap_content" />

		<!-- REGISTRO DE DEVOLUCIÓN -->
		<TextView
				android:text="Registrar nueva devolución"
				android:textStyle="bold"
				android:textSize="16sp"
				android:textColor="#3700B3"
				android:layout_marginBottom="8dp"
				android:layout_width="wrap_content"
				android:layout_height="wrap_content" />

		<EditText
				android:id="@+id/detalleDevolucion"
				android:hint="Detalle de la devolución"
				android:backgroundTint="#FF6200EE"
				android:layout_marginBottom="8dp"
				android:layout_width="match_parent"
				android:layout_height="wrap_content" />

		<Button
				android:id="@+id/btnCrearDevolucion"
				android:text="Registrar Devolución"
				android:onClick="crearDevolucion"
				android:backgroundTint="#FF6200EE"
				android:textColor="#FFFFFF"
				android:layout_width="match_parent"
				android:layout_height="wrap_content" />

		<Button
				android:id="@+id/listarDevoluciones"
				android:text="Listar Devoluciones"
				android:onClick="listarDevoluciones"
				android:backgroundTint="#3700B3"
				android:textColor="#FFFFFF"
				android:layout_marginTop="8dp"
				android:layout_width="match_parent"
				android:layout_height="wrap_content" />

		<!-- ACTUALIZAR DEVOLUCIÓN -->
		<LinearLayout
				android:id="@+id/layoutActualizarDevolucion"
				android:orientation="vertical"
				android:visibility="gone"
				android:layout_marginTop="16dp"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:background="#EEEEEE"
				android:padding="12dp"
				android:layout_marginBottom="8dp"
				android:elevation="2dp">

			<TextView
					android:text="Actualizar Devolución"
					android:textStyle="bold"
					android:textSize="16sp"
					android:layout_marginBottom="8dp"
					android:layout_width="wrap_content"
					android:layout_height="wrap_content" />

			<EditText
					android:id="@+id/editTextDetalle"
					android:hint="Nuevo detalle de devolución"
					android:backgroundTint="#FF6200EE"
					android:layout_marginBottom="8dp"
					android:layout_width="match_parent"
					android:layout_height="wrap_content" />

			<Button
					android:id="@+id/btnActualizarDevolucion"
					android:text="Actualizar Devolución"
					android:onClick="actualizarDevolucion"
					android:backgroundTint="#FF6200EE"
					android:textColor="#FFFFFF"
					android:layout_width="match_parent"
					android:layout_height="wrap_content" />
		</LinearLayout>

		<!-- LISTADO DE DEVOLUCIONES -->
		<TextView
				android:text="Lista de Devoluciones"
				android:textSize="16sp"
				android:textStyle="bold"
				android:layout_marginTop="8dp"
				android:layout_width="wrap_content"
				android:layout_height="wrap_content" />

		<TableLayout
				android:id="@+id/tableDevoluciones"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:stretchColumns="*"
				android:layout_marginTop="8dp"
				android:background="#FAFAFA"
				android:padding="8dp"
				android:elevation="1dp">

			<TableRow>
				<TextView
						android:text="Detalle"
						android:padding="8dp"
						android:textStyle="bold"
						android:textColor="#000000" />

				<TextView
						android:text="Acciones"
						android:padding="8dp"
						android:textStyle="bold"
						android:textColor="#000000" />
			</TableRow>

		</TableLayout>

	</LinearLayout>
</ScrollView>
