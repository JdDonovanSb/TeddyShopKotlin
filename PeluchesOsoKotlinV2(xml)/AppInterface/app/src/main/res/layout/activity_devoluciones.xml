<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
		xmlns:android="http://schemas.android.com/apk/res/android"
		xmlns:tools="http://schemas.android.com/tools"
		xmlns:app="http://schemas.android.com/apk/res-auto"
		android:id="@+id/main"
		android:layout_width="match_parent"
		android:layout_height="match_parent"
		tools:context=".Views.Pedidos.DevolucionesActivity">

	<TextView
			android:id="@+id/textViewTitulo"
			android:layout_width="wrap_content"
			android:layout_height="wrap_content"
			android:text="Formulario Devoluciones"
			app:layout_constraintTop_toTopOf="parent"
			app:layout_constraintStart_toStartOf="parent"
			app:layout_constraintEnd_toEndOf="parent"
			app:layout_constraintVertical_bias="0.008"
			app:layout_constraintBottom_toBottomOf="parent"/>

	<EditText
			android:id="@+id/numDevolucion"
			android:layout_width="0dp"
			android:layout_height="wrap_content"
			android:hint="Numero de la devolución"
			android:inputType="text"
			app:layout_constraintStart_toStartOf="parent"
			app:layout_constraintEnd_toEndOf="parent"
			app:layout_constraintHorizontal_bias="0.0"
			app:layout_constraintBottom_toBottomOf="parent"
			app:layout_constraintTop_toTopOf="parent"
			app:layout_constraintVertical_bias="0.056"/>

	<EditText
			android:id="@+id/detalleDevolucion"
			android:layout_width="0dp"
			android:layout_height="wrap_content"
			android:hint="Detalles de la devolución"
			android:inputType="text"
			app:layout_constraintStart_toStartOf="parent"
			app:layout_constraintEnd_toEndOf="parent"
			app:layout_constraintHorizontal_bias="0.0"
			app:layout_constraintBottom_toBottomOf="parent"
			app:layout_constraintTop_toTopOf="parent"
			app:layout_constraintVertical_bias="0.135"/>
	<EditText
			android:id="@+id/fechaDevolucion"
			android:layout_width="0dp"
			android:layout_height="wrap_content"
			android:hint="Fecha de la devoluvión (DD-MM-AA)"
			android:inputType="text"
			app:layout_constraintStart_toStartOf="parent"
			app:layout_constraintEnd_toEndOf="parent"
			app:layout_constraintHorizontal_bias="0.0"
			app:layout_constraintBottom_toBottomOf="parent"
			app:layout_constraintTop_toTopOf="parent"
			app:layout_constraintVertical_bias="0.201"/>

	<!-- DataTable para mostrar los elementos -->
	<Button
			android:id="@+id/crearDevolucion"
			android:text="Crear"
			android:layout_width="85dp"
			android:layout_height="44dp"
			android:onClick="crearDevolucion"
			app:layout_constraintStart_toStartOf="parent"
			app:layout_constraintEnd_toEndOf="parent"
			app:layout_constraintHorizontal_bias="0.0"
			app:layout_constraintTop_toTopOf="parent"
			app:layout_constraintBottom_toBottomOf="parent"
			app:layout_constraintVertical_bias="0.283"/>
	<Button
			android:id="@+id/listarDevoluciones"
			android:text="Listar"
			android:layout_width="90dp"
			android:layout_height="44dp"
			android:onClick="listarDevoluciones"
			app:layout_constraintStart_toStartOf="parent"
			app:layout_constraintTop_toTopOf="parent"
			app:layout_constraintBottom_toBottomOf="parent"
			app:layout_constraintEnd_toEndOf="parent"
			app:layout_constraintHorizontal_bias="0.299"
			app:layout_constraintVertical_bias="0.283"/>
	<TextView
			android:id="@+id/textViewListado"
			android:text="Visualización de las devoluciones"
			android:layout_width="wrap_content"
			android:layout_height="wrap_content"
			app:layout_constraintStart_toStartOf="parent"
			app:layout_constraintEnd_toEndOf="parent"
			android:layout_marginTop="8dp"
			app:layout_constraintBottom_toBottomOf="parent"
			app:layout_constraintVertical_bias="0.34"
			app:layout_constraintTop_toTopOf="parent" app:layout_constraintHorizontal_bias="0.422"/>
	<ScrollView
			android:layout_width="0dp"
			android:layout_height="0dp"
			app:layout_constraintTop_toBottomOf="@id/textViewListado"
			app:layout_constraintStart_toStartOf="parent"
			app:layout_constraintEnd_toEndOf="parent"
			app:layout_constraintBottom_toBottomOf="parent"
			android:fillViewport="true" app:layout_constraintHorizontal_bias="1.0"
			app:layout_constraintVertical_bias="1.0">

		<TableLayout
				android:id="@+id/tableDevoluciones"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:stretchColumns="*"
				android:padding="8dp">

			<TableRow
					android:layout_width="wrap_content"
					android:layout_height="54dp"
					android:background="#DDDDDD">

				<TextView
						android:layout_width="0dp"
						android:layout_height="wrap_content"
						android:layout_weight="1"
						android:text="Fecha"
						android:padding="8dp"
						android:textStyle="bold"/>

				<TextView
						android:layout_width="0dp"
						android:layout_height="wrap_content"
						android:layout_weight="1"
						android:text="Detalles"
						android:padding="8dp"
						android:textStyle="bold"/>


				<TextView
						android:layout_width="0dp"
						android:layout_height="wrap_content"
						android:layout_weight="1.5"
						android:text="Acciones"
						android:padding="8dp"
						android:textStyle="bold"/>
			</TableRow>
		</TableLayout>
	</ScrollView>

	<androidx.constraintlayout.widget.ConstraintLayout
			android:id="@+id/layoutActualizarDevolucion"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:padding="16dp"
			android:visibility="gone"
			app:layout_constraintTop_toTopOf="parent"
			app:layout_constraintStart_toStartOf="parent"
			app:layout_constraintEnd_toEndOf="parent"
			android:background="@android:color/white">

		<TextView
				android:id="@+id/textViewTituloDialog"
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:text="Actualizar Devolución"
				android:textSize="18sp"
				android:textStyle="bold"
				app:layout_constraintTop_toTopOf="parent"
				app:layout_constraintStart_toStartOf="parent"
				app:layout_constraintEnd_toEndOf="parent" />

		<EditText
				android:id="@+id/editTextNum"
				android:layout_width="0dp"
				android:layout_height="wrap_content"
				android:hint="Numero del detalle"
				android:inputType="text"
				app:layout_constraintStart_toStartOf="parent"
				app:layout_constraintEnd_toEndOf="parent"
				app:layout_constraintTop_toBottomOf="@id/textViewTituloDialog"
				android:layout_marginTop="8dp"/>

		<EditText
				android:id="@+id/editTextDetalle"
				android:layout_width="0dp"
				android:layout_height="wrap_content"
				android:hint="Deatalle de la devolución"
				android:inputType="text"
				app:layout_constraintStart_toStartOf="parent"
				app:layout_constraintEnd_toEndOf="parent"
				app:layout_constraintTop_toBottomOf="@id/textViewTituloDialog"
				android:layout_marginTop="8dp"/>

		<EditText
				android:id="@+id/editTextFecha"
				android:layout_width="0dp"
				android:layout_height="wrap_content"
				android:hint="Fecha de la devolución"
				android:inputType="text"
				app:layout_constraintStart_toStartOf="parent"
				app:layout_constraintEnd_toEndOf="parent"
				app:layout_constraintTop_toBottomOf="@id/textViewTituloDialog"
				android:layout_marginTop="8dp"/>


		<Button
				android:id="@+id/btnActualizarDevolucion"
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:text="Actualizar"
				android:onClick="actualizarDevolucion"
				app:layout_constraintTop_toBottomOf="@id/editTextFecha"
				app:layout_constraintStart_toStartOf="parent"
				android:layout_marginTop="16dp"/>

		<Button
				android:id="@+id/btnCancelarDevolucion"
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:text="Cancelar"
				app:layout_constraintTop_toBottomOf="@id/editTextFecha"
				app:layout_constraintEnd_toEndOf="parent"
				android:layout_marginTop="16dp"/>
	</androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>


