<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
		xmlns:android="http://schemas.android.com/apk/res/android"
		xmlns:tools="http://schemas.android.com/tools"
		xmlns:app="http://schemas.android.com/apk/res-auto"
		android:id="@+id/main"
		android:layout_width="match_parent"
		android:layout_height="match_parent"
		tools:context=".Views.Usuarios.RolesActivity">

	<TextView
			android:id="@+id/textViewTituloRol"
			android:layout_width="wrap_content"
			android:layout_height="wrap_content"
			android:text="Formulario Roles"
			app:layout_constraintTop_toTopOf="parent"
			app:layout_constraintStart_toStartOf="parent"
			app:layout_constraintEnd_toEndOf="parent" app:layout_constraintBottom_toBottomOf="parent"
			app:layout_constraintHorizontal_bias="0.498" app:layout_constraintVertical_bias="0.008"/>

	<EditText
			android:id="@+id/nombreRol"
			android:layout_width="411dp"
			android:layout_height="wrap_content"
			android:hint="Nombre"
			android:inputType="text"
			app:layout_constraintBottom_toBottomOf="parent"
			app:layout_constraintTop_toTopOf="parent"
			app:layout_constraintStart_toStartOf="parent"
			app:layout_constraintVertical_bias="0.055"
			app:layout_constraintEnd_toEndOf="parent"
			app:layout_constraintHorizontal_bias="0.0"
			android:minHeight="48dp"/>

	<Button
			android:id="@+id/crearRol"
			android:text="Crear rol"
			android:layout_width="wrap_content"
			android:layout_height="wrap_content"
			android:onClick="crearRol"
			app:layout_constraintStart_toStartOf="parent"
			app:layout_constraintBottom_toBottomOf="parent"
			app:layout_constraintEnd_toEndOf="parent"
			app:layout_constraintTop_toTopOf="parent"
			app:layout_constraintHorizontal_bias="0.794"
			app:layout_constraintVertical_bias="0.231"/>

	<TextView
			android:id="@+id/textViewListado"
			android:text="Visualización de los Roles"
			android:layout_width="wrap_content"
			android:layout_height="wrap_content"
			app:layout_constraintEnd_toEndOf="parent"
			app:layout_constraintStart_toStartOf="parent"
			app:layout_constraintBottom_toBottomOf="parent"
			app:layout_constraintTop_toTopOf="parent"
			app:layout_constraintHorizontal_bias="0.459"
			app:layout_constraintVertical_bias="0.331"/>

	<Button
			android:id="@+id/ListarRoles"
			android:text="Listar Roles"
			android:layout_width="wrap_content"
			android:layout_height="wrap_content"
			android:onClick="listarRoles"

			app:layout_constraintEnd_toEndOf="parent"
			app:layout_constraintStart_toStartOf="parent"
			app:layout_constraintBottom_toBottomOf="parent"
			app:layout_constraintHorizontal_bias="0.061"
			app:layout_constraintTop_toTopOf="parent"
			app:layout_constraintVertical_bias="0.232"/>

	<Switch
			android:text="estado"
			android:layout_width="wrap_content"
			android:layout_height="wrap_content"
			android:id="@+id/estadoRol"
			app:layout_constraintTop_toTopOf="parent"
			app:layout_constraintBottom_toBottomOf="parent"
			app:layout_constraintStart_toStartOf="parent"
			app:layout_constraintEnd_toEndOf="parent"
			app:layout_constraintVertical_bias="0.153"
			android:minHeight="48dp"/>
</androidx.constraintlayout.widget.ConstraintLayout>
