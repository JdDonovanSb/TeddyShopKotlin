<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
			android:layout_width="match_parent"
			android:layout_height="match_parent"
			android:padding="16dp"
			android:background="#F5F5F5">

	<LinearLayout
			android:orientation="vertical"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:padding="8dp"
			android:background="@android:color/white"
			android:elevation="4dp"
			android:layout_margin="8dp"
			android:layout_gravity="center"
			android:clipToPadding="false">

		<!-- TÍTULO -->
		<TextView
				android:text="Gestión de Métodos de Pago"
				android:textStyle="bold"
				android:textSize="18sp"
				android:layout_marginBottom="8dp"
				android:layout_width="wrap_content"
				android:layout_height="wrap_content" />

		<!-- REGISTRO DE METODO DE PAGO -->
		<TextView
				android:text="Registrar nuevo método de pago"
				android:textStyle="bold"
				android:textSize="16sp"
				android:textColor="#3700B3"
				android:layout_marginBottom="8dp"
				android:layout_width="wrap_content"
				android:layout_height="wrap_content" />

		<EditText
				android:id="@+id/nombreMetodoPago"
				android:hint="Nombre del Método de Pago"
				android:backgroundTint="#FF6200EE"
				android:layout_marginBottom="8dp"
				android:layout_width="match_parent"
				android:layout_height="wrap_content" />

		<Button
				android:id="@+id/btnCrearMetodoPago"
				android:text="Registrar Método de Pago"
				android:onClick="crearMetodoPago"
				android:backgroundTint="#FF6200EE"
				android:textColor="#FFFFFF"
				android:layout_width="match_parent"
				android:layout_height="wrap_content" />

		<Button
				android:id="@+id/ListarMetodoPagos"
				android:text="Listar Métodos de Pago"
				android:onClick="listarMetodosPago"
				android:backgroundTint="#3700B3"
				android:textColor="#FFFFFF"
				android:layout_marginTop="8dp"
				android:layout_width="match_parent"
				android:layout_height="wrap_content" />

		<!-- ACTUALIZAR METODO DE PAGO -->
		<LinearLayout
				android:id="@+id/layoutActualizarMetodoPago"
				android:orientation="vertical"
				android:visibility="gone"
				android:layout_marginTop="16dp"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:background="#EEEEEE"
				android:padding="12dp"
				android:layout_marginBottom="8dp"
				android:elevation="2dp">

			<TextView
					android:text="Actualizar Método de Pago"
					android:textStyle="bold"
					android:textSize="16sp"
					android:layout_marginBottom="8dp"
					android:layout_width="wrap_content"
					android:layout_height="wrap_content" />

			<EditText
					android:id="@+id/editTextNombreMetodoPago"
					android:hint="Nuevo Nombre"
					android:backgroundTint="#FF6200EE"
					android:layout_marginBottom="8dp"
					android:layout_width="match_parent"
					android:layout_height="wrap_content" />

			<Button
					android:id="@+id/btnActualizarMetodoPago"
					android:text="Actualizar Método de Pago"
					android:onClick="actualizarMetodoPago"
					android:backgroundTint="#FF6200EE"
					android:textColor="#FFFFFF"
					android:layout_width="match_parent"
					android:layout_height="wrap_content" />
		</LinearLayout>

		<!-- LISTADO DE METODOS DE PAGO -->
		<TextView
				android:text="Lista de Métodos de Pago"
				android:textSize="16sp"
				android:textStyle="bold"
				android:layout_marginTop="8dp"
				android:layout_width="wrap_content"
				android:layout_height="wrap_content" />

		<TableLayout
				android:id="@+id/tableMetodosPago"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:stretchColumns="*"
				android:layout_marginTop="8dp"
				android:background="#FAFAFA"
				android:padding="8dp"
				android:elevation="1dp">

			<TableRow>
				<TextView
						android:text="Nombre"
						android:padding="8dp"
						android:textStyle="bold"
						android:textColor="#000000" />

				<TextView
						android:text="Acciones"
						android:padding="8dp"
						android:textStyle="bold"
						android:textColor="#000000" />
			</TableRow>

		</TableLayout>

	</LinearLayout>
</ScrollView>
