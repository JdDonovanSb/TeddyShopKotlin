<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
		xmlns:android="http://schemas.android.com/apk/res/android"
		xmlns:tools="http://schemas.android.com/tools"
		xmlns:app="http://schemas.android.com/apk/res-auto"
		android:id="@+id/main"
		android:layout_width="match_parent"
		android:layout_height="match_parent"
		tools:context=".Views.Pedidos.MetodoPagoActivity">

	<TextView
			android:id="@+id/textViewTituloMetodoPago"
			android:layout_width="wrap_content"
			android:layout_height="wrap_content"
			android:text="Formulario de Metodos de Pago"
			app:layout_constraintTop_toTopOf="parent"
			app:layout_constraintStart_toStartOf="parent"
			app:layout_constraintEnd_toEndOf="parent" app:layout_constraintBottom_toBottomOf="parent"
			app:layout_constraintHorizontal_bias="0.498" app:layout_constraintVertical_bias="0.008"/>

	<EditText
			android:id="@+id/nombreMetodoPago"
			android:layout_width="411dp"
			android:layout_height="wrap_content"
			android:hint="Nombre del metodo de pago"
			android:inputType="text"
			app:layout_constraintBottom_toBottomOf="parent"
			app:layout_constraintTop_toTopOf="parent"
			app:layout_constraintStart_toStartOf="parent"
			app:layout_constraintVertical_bias="0.055"
			app:layout_constraintEnd_toEndOf="parent"
			app:layout_constraintHorizontal_bias="0.0"
			android:minHeight="48dp"/>

	<Button
			android:id="@+id/crearMetodoPago"
			android:text="Crear Metodo Pago"
			android:layout_width="wrap_content"
			android:layout_height="wrap_content"
			android:onClick="crearMetodoPago"
			app:layout_constraintStart_toStartOf="parent"
			app:layout_constraintBottom_toBottomOf="parent"
			app:layout_constraintEnd_toEndOf="parent"
			app:layout_constraintTop_toTopOf="parent"
			app:layout_constraintHorizontal_bias="1.0"
			app:layout_constraintVertical_bias="0.231"/>

	<TextView
			android:id="@+id/textViewListado"
			android:text="Visualización de los metodos de pago"
			android:layout_width="wrap_content"
			android:layout_height="wrap_content"
			app:layout_constraintEnd_toEndOf="parent"
			app:layout_constraintStart_toStartOf="parent"
			app:layout_constraintBottom_toBottomOf="parent"
			app:layout_constraintTop_toTopOf="parent"
			app:layout_constraintHorizontal_bias="0.459"
			app:layout_constraintVertical_bias="0.331"/>

	<Button
			android:id="@+id/ListarMetodoPagos"
			android:text="Listar Metodos de pago"
			android:layout_width="wrap_content"
			android:layout_height="wrap_content"
			android:onClick="listarMetodoPagos"

			app:layout_constraintEnd_toEndOf="parent"
			app:layout_constraintStart_toStartOf="parent"
			app:layout_constraintBottom_toBottomOf="parent"
			app:layout_constraintHorizontal_bias="0.0"
			app:layout_constraintTop_toTopOf="parent"
			app:layout_constraintVertical_bias="0.231"/>


</androidx.constraintlayout.widget.ConstraintLayout>
