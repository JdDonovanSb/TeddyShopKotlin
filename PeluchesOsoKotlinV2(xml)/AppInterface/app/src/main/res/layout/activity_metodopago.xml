<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
			xmlns:app="http://schemas.android.com/apk/res-auto"
			xmlns:tools="http://schemas.android.com/tools"
			android:layout_width="match_parent"
			android:layout_height="match_parent"
			tools:context=".Views.Pedidos.MetodoPagoActivity">

	<LinearLayout
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:orientation="vertical"
			android:padding="16dp">

		<!-- Título -->
		<TextView
				android:id="@+id/textViewTituloMetodoPago"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:text="Formulario de Métodos de Pago"
				android:textSize="18sp"
				android:textStyle="bold"
				android:gravity="center"
				android:layout_marginBottom="16dp" />

		<!-- Campo para crear nuevo método de pago -->
		<EditText
				android:id="@+id/nombreMetodoPago"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:hint="Nombre del método de pago"
				android:inputType="text"
				android:minHeight="48dp" />

		<!-- Botón Crear -->
		<Button
				android:id="@+id/crearMetodoPago"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:text="Crear Método de Pago"
				android:onClick="crearMetodoPago"
				android:layout_marginTop="8dp" />

		<!-- Botón Listar -->
		<Button
				android:id="@+id/ListarMetodoPagos"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:text="Listar Métodos de Pago"
				android:onClick="listarMetodosPago"
				android:layout_marginTop="8dp" />

		<!-- Sección para actualizar método de pago -->
		<LinearLayout
				android:id="@+id/layoutActualizarMetodoPago"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:orientation="vertical"
				android:visibility="gone"
				android:layout_marginTop="16dp"
				android:background="@android:color/darker_gray"
				android:padding="12dp">

			<TextView
					android:layout_width="match_parent"
					android:layout_height="wrap_content"
					android:text="Actualizar Método de Pago"
					android:textStyle="bold"
					android:textSize="16sp"
					android:layout_marginBottom="8dp" />

			<EditText
					android:id="@+id/editTextNombreMetodoPago"
					android:layout_width="match_parent"
					android:layout_height="wrap_content"
					android:hint="Nuevo nombre"
					android:inputType="text" />

			<Button
					android:id="@+id/btnActualizarMetodoPago"
					android:layout_width="match_parent"
					android:layout_height="wrap_content"
					android:text="Actualizar"
					android:onClick="actualizarMetodoPago"
					android:layout_marginTop="8dp" />
		</LinearLayout>

		<!-- Título de la lista -->
		<TextView
				android:id="@+id/textViewListado"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:text="Visualización de los métodos de pago"
				android:textStyle="bold"
				android:textSize="16sp"
				android:layout_marginTop="24dp"
				android:gravity="center" />

		<!-- Tabla para mostrar resultados -->
		<TableLayout
				android:id="@+id/tableMetodosPago"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:stretchColumns="*"
				android:layout_marginTop="8dp"
				android:background="#DDDDDD"
				android:padding="8dp">

			<TableRow>
				<TextView
						android:layout_width="0dp"
						android:layout_height="wrap_content"
						android:layout_weight="1"
						android:text="Nombre"
						android:textStyle="bold"
						android:padding="8dp" />
				<TextView
						android:layout_width="0dp"
						android:layout_height="wrap_content"
						android:layout_weight="1.5"
						android:text="Acciones"
						android:textStyle="bold"
						android:padding="8dp" />
			</TableRow>
		</TableLayout>

	</LinearLayout>
</ScrollView>
