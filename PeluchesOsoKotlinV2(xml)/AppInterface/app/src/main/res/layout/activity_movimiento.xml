<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
			xmlns:app="http://schemas.android.com/apk/res-auto"
			xmlns:tools="http://schemas.android.com/tools"
			android:layout_width="match_parent"
			android:layout_height="match_parent"
			android:padding="16dp"
			tools:context=".Views.Productos.MovimientoActivity">

	<LinearLayout
			android:orientation="vertical"
			android:layout_width="match_parent"
			android:layout_height="wrap_content">

		<!-- ENCABEZADO -->
		<TextView
				android:text="Gestión de Movimientos"
				android:textSize="24sp"
				android:textStyle="bold"
				android:gravity="center"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:paddingBottom="16dp" />

		<!-- CAMPOS DE CREACIÓN -->
		<EditText
				android:id="@+id/fechaMovimiento"
				android:hint="Fecha del Movimiento"
				android:layout_width="match_parent"
				android:layout_height="wrap_content" />

		<EditText
				android:id="@+id/cantidadIngreso"
				android:hint="Cantidad Ingreso"
				android:inputType="number"
				android:layout_width="match_parent"
				android:layout_height="wrap_content" />

		<EditText
				android:id="@+id/cantidadVendida"
				android:hint="Cantidad Vendida"
				android:inputType="number"
				android:layout_width="match_parent"
				android:layout_height="wrap_content" />

		<!-- BOTONES DE CREACIÓN Y LISTADO -->
		<LinearLayout
				android:orientation="horizontal"
				android:gravity="center"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:layout_marginTop="8dp"
				android:layout_marginBottom="8dp">

			<Button
					android:id="@+id/btnCrearMovimiento"
					android:onClick="crearMovimiento"
					android:text="Crear"
					android:layout_width="wrap_content"
					android:layout_height="wrap_content"
					android:layout_marginEnd="8dp" />

			<Button
					android:id="@+id/btnListarMovimientos"
					android:onClick="listarMovimientos"
					android:text="Listar"
					android:layout_width="wrap_content"
					android:layout_height="wrap_content" />
		</LinearLayout>

		<!-- LAYOUT DE ACTUALIZACIÓN OCULTO -->
		<LinearLayout
				android:id="@+id/layoutActualizarMovimiento"
				android:orientation="vertical"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:padding="8dp"
				android:background="#eeeeee"
				android:visibility="gone">

			<TextView
					android:text="Actualizar Movimiento"
					android:textStyle="bold"
					android:layout_width="wrap_content"
					android:layout_height="wrap_content" />

			<EditText
					android:id="@+id/editTextFecha"
					android:hint="Nueva Fecha"
					android:layout_width="match_parent"
					android:layout_height="wrap_content" />

			<EditText
					android:id="@+id/editTextIngreso"
					android:hint="Nuevo Ingreso"
					android:inputType="number"
					android:layout_width="match_parent"
					android:layout_height="wrap_content" />

			<EditText
					android:id="@+id/editTextVenta"
					android:hint="Nueva Venta"
					android:inputType="number"
					android:layout_width="match_parent"
					android:layout_height="wrap_content" />

			<Button
					android:id="@+id/btnActualizarMovimiento"
					android:onClick="actualizarMovimiento"
					android:text="Actualizar"
					android:layout_width="wrap_content"
					android:layout_height="wrap_content"
					android:layout_marginTop="8dp" />
		</LinearLayout>

		<!-- TABLA DE MOVIMIENTOS -->
		<TextView
				android:text="Lista de Movimientos"
				android:textStyle="bold"
				android:layout_marginTop="16dp"
				android:layout_width="wrap_content"
				android:layout_height="wrap_content" />

		<ScrollView
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:fillViewport="true">

			<TableLayout
					android:id="@+id/tableMovimientos"
					android:layout_width="match_parent"
					android:layout_height="wrap_content"
					android:stretchColumns="*">

				<TableRow
						android:layout_width="wrap_content"
						android:layout_height="wrap_content"
						android:background="#DDDDDD">

					<TextView
							android:layout_width="0dp"
							android:layout_height="wrap_content"
							android:layout_weight="1"
							android:text="Fecha"
							android:textStyle="bold"
							android:gravity="center"
							android:padding="8dp" />

					<TextView
							android:layout_width="0dp"
							android:layout_height="wrap_content"
							android:layout_weight="1"
							android:text="Ingreso"
							android:textStyle="bold"
							android:gravity="center"
							android:padding="8dp" />

					<TextView
							android:layout_width="0dp"
							android:layout_height="wrap_content"
							android:layout_weight="1"
							android:text="Venta"
							android:textStyle="bold"
							android:gravity="center"
							android:padding="8dp" />

					<TextView
							android:layout_width="0dp"
							android:layout_height="wrap_content"
							android:layout_weight="1.5"
							android:text="Acciones"
							android:textStyle="bold"
							android:gravity="center"
							android:padding="8dp" />
				</TableRow>

			</TableLayout>
		</ScrollView>

	</LinearLayout>
</ScrollView>
