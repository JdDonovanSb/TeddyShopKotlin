<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
		xmlns:android="http://schemas.android.com/apk/res/android"
		xmlns:app="http://schemas.android.com/apk/res-auto"
		xmlns:tools="http://schemas.android.com/tools"
		android:layout_width="match_parent"
		android:layout_height="match_parent"
		tools:context=".Views.Productos.MovimientoActivity">

	<TextView
			android:id="@+id/textViewTitulo"
			android:layout_width="wrap_content"
			android:layout_height="wrap_content"
			android:text="Formulario Movimientos"
			app:layout_constraintTop_toTopOf="parent"
			app:layout_constraintStart_toStartOf="parent"
			app:layout_constraintEnd_toEndOf="parent"
			app:layout_constraintHorizontal_bias="0.5"/>

	<EditText
			android:id="@+id/fechaMovimiento"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:hint="Fecha (YYYY-MM-DD)"
			android:inputType="date"
			app:layout_constraintTop_toBottomOf="@id/textViewTitulo"
			app:layout_constraintStart_toStartOf="parent"
			app:layout_constraintEnd_toEndOf="parent"/>

	<EditText
			android:id="@+id/cantidadIngreso"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:hint="Cantidad de Ingreso"
			android:inputType="number"
			app:layout_constraintTop_toBottomOf="@id/fechaMovimiento"
			app:layout_constraintStart_toStartOf="parent"
			app:layout_constraintEnd_toEndOf="parent"/>

	<EditText
			android:id="@+id/cantidadSalida"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:hint="Cantidad de Salida"
			android:inputType="number"
			app:layout_constraintTop_toBottomOf="@id/cantidadIngreso"
			app:layout_constraintStart_toStartOf="parent"
			app:layout_constraintEnd_toEndOf="parent"/>

	<Button
			android:id="@+id/crearMovimiento"
			android:layout_width="wrap_content"
			android:layout_height="wrap_content"
			android:text="Crear Movimiento"
			android:onClick="crearMovimiento"
			app:layout_constraintTop_toBottomOf="@id/cantidadSalida"
			app:layout_constraintStart_toStartOf="parent"
			app:layout_constraintEnd_toEndOf="parent"
			app:layout_constraintHorizontal_bias="0.936"
			android:layout_marginTop="36dp"/>

	<Button
			android:id="@+id/listarMovimientos"
			android:layout_width="wrap_content"
			android:layout_height="wrap_content"
			android:text="Listar Movimientos"
			android:onClick="listarMovimientos"
			app:layout_constraintStart_toStartOf="parent"
			app:layout_constraintEnd_toEndOf="parent"
			app:layout_constraintHorizontal_bias="0.066"
			app:layout_constraintTop_toTopOf="parent"
			app:layout_constraintBottom_toBottomOf="parent"
			app:layout_constraintVertical_bias="0.278"/>

	<TextView
			android:id="@+id/textViewMovimientos"
			android:layout_width="wrap_content"
			android:layout_height="wrap_content"
			android:text="Visualización de los movimientos"
			app:layout_constraintTop_toBottomOf="@id/listarMovimientos"
			app:layout_constraintStart_toStartOf="parent"
			app:layout_constraintEnd_toEndOf="parent"
			android:layout_marginTop="24dp"
			app:layout_constraintHorizontal_bias="0.497"/>

</androidx.constraintlayout.widget.ConstraintLayout>