<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
		xmlns:android="http://schemas.android.com/apk/res/android"
		xmlns:tools="http://schemas.android.com/tools"
		xmlns:app="http://schemas.android.com/apk/res-auto"
		android:layout_width="match_parent"
		android:layout_height="match_parent"
		tools:context=".Views.Usuarios.EmpleadosActivity">

	<TextView
			android:id="@+id/textViewTituloEmpleado"
			android:layout_width="wrap_content"
			android:layout_height="wrap_content"
			android:text="Formulario Empleados"
			app:layout_constraintTop_toTopOf="parent"
			app:layout_constraintStart_toStartOf="parent"
			app:layout_constraintEnd_toEndOf="parent"
			app:layout_constraintVertical_bias="0.008"/>

	<EditText
			android:id="@+id/DniEmpleado"
			android:layout_width="0dp"
			android:layout_height="wrap_content"
			android:hint="DNI"
			android:inputType="text"
			app:layout_constraintStart_toStartOf="parent"
			app:layout_constraintEnd_toEndOf="parent"
			app:layout_constraintTop_toTopOf="parent"
			app:layout_constraintVertical_bias="0.061"/>

	<EditText
			android:id="@+id/NombreEmpleado"
			android:layout_width="0dp"
			android:layout_height="wrap_content"
			android:hint="Nombre"
			android:inputType="text"
			app:layout_constraintStart_toStartOf="parent"
			app:layout_constraintEnd_toEndOf="parent"
			app:layout_constraintTop_toTopOf="@+id/textViewTituloEmpleado"
			android:layout_marginTop="44dp"
			app:layout_constraintHorizontal_bias="0.0"/>

	<EditText
			android:id="@+id/TelefonoEmpleado"
			android:layout_width="0dp"
			android:layout_height="wrap_content"
			android:hint="Teléfono"
			android:inputType="phone"
			app:layout_constraintStart_toStartOf="parent"
			app:layout_constraintEnd_toEndOf="parent"
			app:layout_constraintTop_toTopOf="@+id/textViewTituloEmpleado"
			android:layout_marginTop="96dp"
			app:layout_constraintHorizontal_bias="0.0"/>

	<Button
			android:id="@+id/crearEmpleado"
			android:text="Crear Empleado"
			android:layout_width="159dp"
			android:layout_height="47dp"
			android:onClick="crearEmpleado"
			app:layout_constraintStart_toStartOf="parent"
			app:layout_constraintEnd_toEndOf="parent"
			app:layout_constraintHorizontal_bias="0.13"
			app:layout_constraintVertical_bias="0.402"
			app:layout_constraintTop_toTopOf="parent"
			app:layout_constraintBottom_toBottomOf="parent"/>

	<Button
			android:id="@+id/listarEmpleados"
			android:text="Listar Empleados"
			android:layout_width="159dp"
			android:layout_height="47dp"
			android:onClick="listarEmpleados"
			app:layout_constraintStart_toStartOf="parent"
			app:layout_constraintEnd_toEndOf="parent"
			app:layout_constraintHorizontal_bias="0.869"
			app:layout_constraintVertical_bias="0.402"
			app:layout_constraintTop_toTopOf="parent"
			app:layout_constraintBottom_toBottomOf="parent"/>

	<TextView
			android:id="@+id/textViewListado"
			android:text="Visualización de los empleados"
			android:layout_width="wrap_content"
			android:layout_height="wrap_content"
			app:layout_constraintStart_toStartOf="parent"
			app:layout_constraintEnd_toEndOf="parent"
			app:layout_constraintTop_toTopOf="parent"
			app:layout_constraintBottom_toBottomOf="parent"
			app:layout_constraintVertical_bias="0.583"/>

	<ScrollView
			android:layout_width="0dp"
			android:layout_height="0dp"
			app:layout_constraintTop_toBottomOf="@id/textViewListado"
			app:layout_constraintStart_toStartOf="parent"
			app:layout_constraintEnd_toEndOf="parent"
			app:layout_constraintBottom_toBottomOf="parent"
			android:fillViewport="true">

		<TableLayout
				android:id="@+id/tableEmpleados"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:stretchColumns="*"
				android:padding="8dp">

			<TableRow
					android:layout_width="wrap_content"
					android:layout_height="54dp"
					android:background="#DDDDDD">

				<TextView
						android:layout_width="0dp"
						android:layout_height="wrap_content"
						android:layout_weight="1"
						android:text="Nombre"
						android:padding="8dp"
						android:textStyle="bold"/>
				<TextView
						android:layout_width="0dp"
						android:layout_height="wrap_content"
						android:layout_weight="1"
						android:text="DNI"
						android:padding="8dp"
						android:textStyle="bold"/>

				<TextView
						android:layout_width="0dp"
						android:layout_height="wrap_content"
						android:layout_weight="1"
						android:text="Teléfono"
						android:padding="8dp"
						android:textStyle="bold"/>

				<TextView
						android:layout_width="0dp"
						android:layout_height="wrap_content"
						android:layout_weight="1.5"
						android:text="Acciones"
						android:padding="8dp"
						android:textStyle="bold"/>
			</TableRow>
		</TableLayout>
	</ScrollView>

	<androidx.constraintlayout.widget.ConstraintLayout
			android:id="@+id/layoutActualizarEmpleado"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:padding="16dp"
			android:visibility="gone"
			app:layout_constraintTop_toTopOf="parent"
			app:layout_constraintStart_toStartOf="parent"
			app:layout_constraintEnd_toEndOf="parent"
			android:background="@android:color/white">

		<TextView
				android:id="@+id/textViewTituloDialogEmpleado"
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:text="Actualizar Empleado"
				android:textSize="18sp"
				android:textStyle="bold"
				app:layout_constraintTop_toTopOf="parent"
				app:layout_constraintStart_toStartOf="parent"
				app:layout_constraintEnd_toEndOf="parent" />

		<EditText
				android:id="@+id/editTextDniEmpleado"
				android:layout_width="0dp"
				android:layout_height="wrap_content"
				android:hint="Dni"
				android:inputType="text"
				app:layout_constraintTop_toBottomOf="@id/textViewTituloDialogEmpleado"
				app:layout_constraintStart_toStartOf="parent"
				app:layout_constraintEnd_toEndOf="parent"
				android:layout_marginTop="8dp" />

		<EditText
				android:id="@+id/editTextNombreEmpleado"
				android:layout_width="0dp"
				android:layout_height="wrap_content"
				android:hint="Nombre"
				android:inputType="text"
				app:layout_constraintTop_toBottomOf="@id/editTextDniEmpleado"
				app:layout_constraintStart_toStartOf="parent"
				app:layout_constraintEnd_toEndOf="parent"
				android:layout_marginTop="8dp" />

		<EditText
				android:id="@+id/editTextTelefonoEmpleado"
				android:layout_width="0dp"
				android:layout_height="wrap_content"
				android:hint="Teléfono"
				android:inputType="phone"
				app:layout_constraintTop_toBottomOf="@id/editTextNombreEmpleado"
				app:layout_constraintStart_toStartOf="parent"
				app:layout_constraintEnd_toEndOf="parent"
				android:layout_marginTop="8dp" />

		<Button
				android:id="@+id/btnActualizarEmpleado"
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:text="Actualizar"
				android:onClick="actualizarEmpleado"
				app:layout_constraintTop_toBottomOf="@id/editTextTelefonoEmpleado"
				app:layout_constraintStart_toStartOf="parent"
				android:layout_marginTop="16dp" />

		<Button
				android:id="@+id/btnCancelarActualizarEmpleado"
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:text="Cancelar"
				app:layout_constraintTop_toBottomOf="@id/editTextTelefonoEmpleado"
				app:layout_constraintEnd_toEndOf="parent"
				android:layout_marginTop="16dp" />
	</androidx.constraintlayout.widget.ConstraintLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
