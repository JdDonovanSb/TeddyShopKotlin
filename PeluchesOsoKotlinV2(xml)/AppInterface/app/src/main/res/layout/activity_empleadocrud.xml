<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
			android:layout_width="match_parent"
			android:layout_height="match_parent"
			android:padding="16dp"
			android:background="#F5F5F5">

	<LinearLayout
			android:orientation="vertical"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:padding="8dp"
			android:background="@android:color/white"
			android:elevation="4dp"
			android:layout_margin="8dp"
			android:layout_gravity="center"
			android:clipToPadding="false">

		<!-- TÍTULO -->
		<TextView
				android:text="Gestión de Empleados"
				android:textStyle="bold"
				android:textSize="18sp"
				android:layout_marginBottom="8dp"
				android:layout_width="wrap_content"
				android:layout_height="wrap_content" />

		<!-- REGISTRO DE EMPLEADO -->
		<TextView
				android:text="Registrar nuevo empleado"
				android:textStyle="bold"
				android:textSize="16sp"
				android:textColor="#3700B3"
				android:layout_marginBottom="8dp"
				android:layout_width="wrap_content"
				android:layout_height="wrap_content" />

		<EditText
				android:id="@+id/NombreEmpleado"
				android:hint="Nombre"
				android:backgroundTint="#FF6200EE"
				android:layout_marginBottom="8dp"
				android:layout_width="match_parent"
				android:layout_height="wrap_content" />

		<EditText
				android:id="@+id/DniEmpleado"
				android:hint="DNI"
				android:inputType="number"
				android:backgroundTint="#FF6200EE"
				android:layout_marginBottom="8dp"
				android:layout_width="match_parent"
				android:layout_height="wrap_content" />

		<EditText
				android:id="@+id/TelefonoEmpleado"
				android:hint="Teléfono"
				android:inputType="phone"
				android:backgroundTint="#FF6200EE"
				android:layout_marginBottom="12dp"
				android:layout_width="match_parent"
				android:layout_height="wrap_content" />

		<Button
				android:id="@+id/btnCrearEmpleado"
				android:text="Registrar Empleado"
				android:onClick="crearEmpleado"
				android:backgroundTint="#FF6200EE"
				android:textColor="#FFFFFF"
				android:layout_width="match_parent"
				android:layout_height="wrap_content" />

		<Button
				android:id="@+id/listarEmpleados"
				android:text="Listar Empleados"
				android:onClick="listarEmpleados"
				android:backgroundTint="#3700B3"
				android:textColor="#FFFFFF"
				android:layout_marginTop="8dp"
				android:layout_width="match_parent"
				android:layout_height="wrap_content" />

		<!-- ACTUALIZAR EMPLEADO -->
		<LinearLayout
				android:id="@+id/layoutActualizarEmpleado"
				android:orientation="vertical"
				android:visibility="gone"
				android:layout_marginTop="16dp"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:background="#EEEEEE"
				android:padding="12dp"
				android:layout_marginBottom="8dp"
				android:elevation="2dp">

			<TextView
					android:text="Actualizar Empleado"
					android:textStyle="bold"
					android:textSize="16sp"
					android:layout_marginBottom="8dp"
					android:layout_width="wrap_content"
					android:layout_height="wrap_content" />

			<EditText
					android:id="@+id/editTextNombreEmpleado"
					android:hint="Nuevo Nombre"
					android:backgroundTint="#FF6200EE"
					android:layout_marginBottom="8dp"
					android:layout_width="match_parent"
					android:layout_height="wrap_content" />

			<EditText
					android:id="@+id/editTextDniEmpleado"
					android:hint="Nuevo DNI"
					android:inputType="number"
					android:backgroundTint="#FF6200EE"
					android:layout_marginBottom="8dp"
					android:layout_width="match_parent"
					android:layout_height="wrap_content" />

			<EditText
					android:id="@+id/editTextTelefonoEmpleado"
					android:hint="Nuevo Teléfono"
					android:inputType="phone"
					android:backgroundTint="#FF6200EE"
					android:layout_marginBottom="8dp"
					android:layout_width="match_parent"
					android:layout_height="wrap_content" />

			<Button
					android:id="@+id/btnActualizarEmpleado"
					android:text="Actualizar Empleado"
					android:onClick="actualizarEmpleado"
					android:backgroundTint="#FF6200EE"
					android:textColor="#FFFFFF"
					android:layout_width="match_parent"
					android:layout_height="wrap_content" />
		</LinearLayout>

		<!-- LISTADO DE EMPLEADOS -->
		<TextView
				android:text="Lista de empleados"
				android:textSize="16sp"
				android:textStyle="bold"
				android:layout_marginTop="8dp"
				android:layout_width="wrap_content"
				android:layout_height="wrap_content" />

		<TableLayout
				android:id="@+id/tableEmpleados"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:stretchColumns="*"
				android:layout_marginTop="8dp"
				android:background="#FAFAFA"
				android:padding="8dp"
				android:elevation="1dp">

			<TableRow>
				<TextView
						android:text="Nombre"
						android:padding="8dp"
						android:textStyle="bold"
						android:textColor="#000000" />

				<TextView
						android:text="DNI"
						android:padding="8dp"
						android:textStyle="bold"
						android:textColor="#000000" />

				<TextView
						android:text="Teléfono"
						android:padding="8dp"
						android:textStyle="bold"
						android:textColor="#000000" />

				<TextView
						android:text="Acciones"
						android:padding="8dp"
						android:textStyle="bold"
						android:textColor="#000000" />
			</TableRow>


		</TableLayout>

	</LinearLayout>
</ScrollView>
