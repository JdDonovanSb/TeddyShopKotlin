<?xml version="1.0" encoding="utf-8"?>
<ScrollView
		xmlns:android="http://schemas.android.com/apk/res/android"
		xmlns:tools="http://schemas.android.com/tools"
		xmlns:app="http://schemas.android.com/apk/res-auto"
		android:layout_width="match_parent"
		android:layout_height="match_parent"
		tools:context=".Views.Productos.HistorialPrecioActivity">


	<LinearLayout
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:orientation="vertical"
			android:padding="16dp">

		<!-- Título -->
		<TextView
				android:id="@+id/textViewTitulo"
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:text="Gestión de Historial de Precios"
				android:textAppearance="?android:attr/textAppearanceLarge"
				android:layout_gravity="center_horizontal"
				android:paddingBottom="16dp"/>

		<!-- Formulario de creación -->
		<EditText
				android:id="@+id/precio"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:hint="Precio" />

		<EditText
				android:id="@+id/fechaInicio"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:hint="Fecha Inicio" />

		<EditText
				android:id="@+id/fechaFin"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:hint="Fecha Fin" />

		<Switch
				android:id="@+id/estadoPrecio"
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:text="Estado" />

		<Button
				android:id="@+id/crearHistorial"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:onClick="crearHistorial"
				android:text="Crear Historial" />

		<Button
				android:id="@+id/listarHistorial"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:onClick="listarHistorial"
				android:text="Listar Historial" />

		<!-- Tabla -->
		<HorizontalScrollView
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:paddingTop="16dp">

			<TableLayout
					android:id="@+id/tableHistorial"
					android:layout_width="wrap_content"
					android:layout_height="wrap_content"
					android:stretchColumns="*"
					android:shrinkColumns="*">

				<!-- Encabezado -->
				<TableRow>
					<TextView
							android:text="Precio"
							android:textStyle="bold"
							android:padding="8dp"/>
					<TextView
							android:text="Inicio"
							android:textStyle="bold"
							android:padding="8dp"/>
					<TextView
							android:text="Estado"
							android:textStyle="bold"
							android:padding="8dp"/>
					<TextView
							android:text="Acciones"
							android:textStyle="bold"
							android:padding="8dp"/>
				</TableRow>
			</TableLayout>
		</HorizontalScrollView>

		<!-- Layout de actualización (oculto) -->
		<androidx.constraintlayout.widget.ConstraintLayout
				android:id="@+id/layoutActualizarHistorial"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:visibility="gone"
				android:layout_marginTop="24dp">

			<TextView
					android:id="@+id/tituloActualizar"
					android:layout_width="0dp"
					android:layout_height="wrap_content"
					android:text="Actualizar Historial"
					android:textStyle="bold"
					android:textSize="18sp"
					app:layout_constraintTop_toTopOf="parent"
					app:layout_constraintStart_toStartOf="parent"
					app:layout_constraintEnd_toEndOf="parent"
					android:layout_marginBottom="8dp"/>

			<EditText
					android:id="@+id/editTextPrecio"
					android:layout_width="0dp"
					android:layout_height="wrap_content"
					android:hint="Nuevo Precio"
					app:layout_constraintTop_toBottomOf="@+id/tituloActualizar"
					app:layout_constraintStart_toStartOf="parent"
					app:layout_constraintEnd_toEndOf="parent"/>

			<EditText
					android:id="@+id/editTextFechaInicio"
					android:layout_width="0dp"
					android:layout_height="wrap_content"
					android:hint="Nueva Fecha Inicio"
					app:layout_constraintTop_toBottomOf="@id/editTextPrecio"
					app:layout_constraintStart_toStartOf="parent"
					app:layout_constraintEnd_toEndOf="parent"/>

			<EditText
					android:id="@+id/editTextFechaFin"
					android:layout_width="0dp"
					android:layout_height="wrap_content"
					android:hint="Nueva Fecha Fin"
					app:layout_constraintTop_toBottomOf="@id/editTextFechaInicio"
					app:layout_constraintStart_toStartOf="parent"
					app:layout_constraintEnd_toEndOf="parent"/>

			<Switch
					android:id="@+id/switchEstadoPrecio"
					android:layout_width="wrap_content"
					android:layout_height="wrap_content"
					android:text="Nuevo Estado"
					app:layout_constraintTop_toBottomOf="@id/editTextFechaFin"
					app:layout_constraintStart_toStartOf="parent"/>

			<Button
					android:id="@+id/btnActualizarHistorial"
					android:layout_width="wrap_content"
					android:layout_height="wrap_content"
					android:text="Actualizar"
					android:onClick="actualizarHistorial"
					app:layout_constraintTop_toBottomOf="@id/switchEstadoPrecio"
					app:layout_constraintStart_toStartOf="parent"
					app:layout_constraintEnd_toEndOf="parent"
					android:layout_marginTop="8dp"/>
		</androidx.constraintlayout.widget.ConstraintLayout>

	</LinearLayout>
</ScrollView>
