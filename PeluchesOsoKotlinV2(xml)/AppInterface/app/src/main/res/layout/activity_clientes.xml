<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
			android:layout_width="match_parent"
			android:layout_height="match_parent"
			android:padding="16dp">

	<LinearLayout
			android:orientation="vertical"
			android:layout_width="match_parent"
			android:layout_height="wrap_content">

		<!-- Crear Cliente -->
		<EditText
				android:id="@+id/editTextDni"
				android:hint="DNI"
				android:inputType="text"
				android:layout_width="match_parent"
				android:layout_height="wrap_content" />

		<EditText
				android:id="@+id/editTextNombre"
				android:hint="Nombre"
				android:inputType="textPersonName"
				android:layout_width="match_parent"
				android:layout_height="wrap_content" />

		<EditText
				android:id="@+id/editTextApellido"
				android:hint="Apellido"
				android:inputType="textPersonName"
				android:layout_width="match_parent"
				android:layout_height="wrap_content" />

		<EditText
				android:id="@+id/editTextTelefono"
				android:hint="Teléfono"
				android:inputType="phone"
				android:layout_width="match_parent"
				android:layout_height="wrap_content" />

		<Button
				android:id="@+id/btnCrearCliente"
				android:text="Crear Cliente"
				android:onClick="crearCliente"
				android:layout_width="match_parent"
				android:layout_height="wrap_content" />

		<Button
				android:id="@+id/btnListarClientes"
				android:text="Listar Clientes"
				android:onClick="listarClientes"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:layout_marginTop="8dp" />

		<!-- Buscar Cliente por DNI -->
		<EditText
				android:id="@+id/editTextBuscarDni"
				android:hint="Buscar Cliente por DNI"
				android:inputType="text"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:layout_marginTop="16dp" />

		<Button
				android:id="@+id/btnBuscarCliente"
				android:text="Buscar Cliente"
				android:onClick="buscarClientePorDni"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:layout_marginTop="8dp" />

		<!-- Formulario para actualizar -->
		<LinearLayout
				android:id="@+id/layoutActualizarCliente"
				android:orientation="vertical"
				android:visibility="gone"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:layout_marginTop="16dp">

			<EditText
					android:id="@+id/editTextNombreActualizar"
					android:hint="Nuevo Nombre"
					android:layout_width="match_parent"
					android:layout_height="wrap_content" />

			<EditText
					android:id="@+id/editTextApellidoActualizar"
					android:hint="Nuevo Apellido"
					android:layout_width="match_parent"
					android:layout_height="wrap_content" />

			<EditText
					android:id="@+id/editTextTelefonoActualizar"
					android:hint="Nuevo Teléfono"
					android:layout_width="match_parent"
					android:layout_height="wrap_content" />

			<Button
					android:id="@+id/btnActualizarCliente"
					android:text="Actualizar Cliente"
					android:onClick="actualizarCliente"
					android:layout_width="match_parent"
					android:layout_height="wrap_content" />
		</LinearLayout>

		<!-- Tabla para mostrar los clientes -->
		<TableLayout
				android:id="@+id/tableClientes"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:stretchColumns="*"
				android:layout_marginTop="16dp">

			<!-- Encabezados -->
			<TableRow>
				<TextView
						android:text="Nombre"
						android:padding="8dp"
						android:textStyle="bold" />

				<TextView
						android:text="Apellido"
						android:padding="8dp"
						android:textStyle="bold" />

				<TextView
						android:text="Teléfono"
						android:padding="8dp"
						android:textStyle="bold" />

				<TextView
						android:text="Acciones"
						android:padding="8dp"
						android:textStyle="bold" />
			</TableRow>
		</TableLayout>
	</LinearLayout>
</ScrollView>
