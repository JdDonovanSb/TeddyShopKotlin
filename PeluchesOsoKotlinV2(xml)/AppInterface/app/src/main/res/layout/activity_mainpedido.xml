<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
		xmlns:android="http://schemas.android.com/apk/res/android"
		xmlns:tools="http://schemas.android.com/tools"
		xmlns:app="http://schemas.android.com/apk/res-auto"
		android:id="@+id/main"
		android:layout_width="match_parent"
		android:layout_height="match_parent"
		tools:context=".Views.Pedidos.MainPedidoActivity">


	<Button
			android:id="@+id/btnDetallesPedido"
			android:text="Gestionar Detalles de pedido"
			android:layout_width="198dp"
			android:layout_height="64dp"
			android:onClick="detallepedidoMenu"
			app:layout_constraintTop_toTopOf="parent"
			app:layout_constraintBottom_toBottomOf="parent"
			app:layout_constraintStart_toStartOf="parent"
			app:layout_constraintEnd_toEndOf="parent"
			app:layout_constraintVertical_bias="0.8"
			app:layout_constraintHorizontal_bias="0.455"/>

	<Button
			android:id="@+id/btnDetallesFactura4"
			android:text="Gestionar Detalles de Factura"
			android:layout_width="198dp"
			android:layout_height="64dp"
			android:onClick="detallefacturaMenu"
			app:layout_constraintTop_toTopOf="parent"
			app:layout_constraintBottom_toBottomOf="parent"
			app:layout_constraintStart_toStartOf="parent"
			app:layout_constraintEnd_toEndOf="parent"
			app:layout_constraintVertical_bias="0.682"
			app:layout_constraintHorizontal_bias="0.455"/>

	<TextView
			android:id="@+id/textViewTituloPedido"
			android:layout_width="220dp"
			android:layout_height="48dp"
			android:text="Gestionar Pedidos"
			android:textSize="24sp"
			app:layout_constraintTop_toTopOf="parent"
			app:layout_constraintStart_toStartOf="parent"
			app:layout_constraintEnd_toEndOf="parent"
			app:layout_constraintBottom_toBottomOf="parent"
			app:layout_constraintVertical_bias="0.023"
			app:layout_constraintHorizontal_bias="0.507"/>

	<Button
			android:id="@+id/btnGestionarPedidos"
			android:text="Gestionar Pedidos"
			android:layout_width="199dp"
			android:layout_height="63dp"
			android:onClick="pedidoMenu"
			app:layout_constraintBottom_toBottomOf="parent"
			app:layout_constraintTop_toTopOf="parent"
			app:layout_constraintStart_toStartOf="parent"
			app:layout_constraintEnd_toEndOf="parent"
			app:layout_constraintVertical_bias="0.176"
			app:layout_constraintHorizontal_bias="0.452"/>

	<Button
			android:id="@+id/btnMetodoPago"
			android:text="Gestionar Metodos de Pago"
			android:layout_width="198dp"
			android:layout_height="64dp"
			android:onClick="metodoPagoMenu"
			app:layout_constraintTop_toTopOf="parent"
			app:layout_constraintBottom_toBottomOf="parent"
			app:layout_constraintStart_toStartOf="parent"
			app:layout_constraintEnd_toEndOf="parent"
			app:layout_constraintVertical_bias="0.296"
			app:layout_constraintHorizontal_bias="0.45"/>

	<Button
			android:id="@+id/btnDevoluciones"
			android:text="Gestionar Devoluciones"
			android:layout_width="198dp"
			android:layout_height="64dp"
			android:onClick="devolucionMenu"
			app:layout_constraintTop_toTopOf="parent"
			app:layout_constraintBottom_toBottomOf="parent"
			app:layout_constraintStart_toStartOf="parent"
			app:layout_constraintEnd_toEndOf="parent"
			app:layout_constraintVertical_bias="0.418"
			app:layout_constraintHorizontal_bias="0.45"/>

	<Button
			android:id="@+id/btnFacturas2"
			android:text="Gestionar Facturas"
			android:layout_width="198dp"
			android:layout_height="64dp"
			android:onClick="facturaMenu"
			app:layout_constraintTop_toTopOf="parent"
			app:layout_constraintBottom_toBottomOf="parent"
			app:layout_constraintStart_toStartOf="parent"
			app:layout_constraintEnd_toEndOf="parent"
			app:layout_constraintVertical_bias="0.529"
			app:layout_constraintHorizontal_bias="0.455"/>



</androidx.constraintlayout.widget.ConstraintLayout>
