<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
		xmlns:android="http://schemas.android.com/apk/res/android"
		xmlns:app="http://schemas.android.com/apk/res-auto"
		xmlns:tools="http://schemas.android.com/tools"
		android:id="@+id/main"
		android:layout_width="match_parent"
		android:layout_height="match_parent"
		android:background="@android:color/white"
		tools:context=".Views.Pedidos.MainPedidoActivity">

	<TextView
			android:id="@+id/textViewTituloPedido"
			android:layout_width="wrap_content"
			android:layout_height="wrap_content"
			android:layout_marginTop="24dp"
			android:fontFamily="sans-serif-condensed"
			android:text="Gestionar Pedidos"
			android:textSize="26sp"
			android:textStyle="bold"
			app:layout_constraintEnd_toEndOf="parent"
			app:layout_constraintStart_toStartOf="parent"
			app:layout_constraintTop_toTopOf="parent" />

	<View
			android:id="@+id/divider"
			android:layout_width="match_parent"
			android:layout_height="2dp"
			android:layout_marginTop="8dp"
			android:layout_marginHorizontal="24dp"
			android:background="#EEEEEE"
			app:layout_constraintTop_toBottomOf="@+id/textViewTituloPedido" />

	<Button
			android:id="@+id/btnGestionarPedidos"
			style="@style/Widget.MaterialComponents.Button.OutlinedButton"
			android:layout_width="0dp"
			android:layout_height="60dp"
			android:layout_marginStart="24dp"
			android:layout_marginTop="32dp"
			android:layout_marginEnd="24dp"
			android:elevation="2dp"
			android:fontFamily="sans-serif"
			android:letterSpacing="0.02"
			android:minHeight="60dp"
			android:paddingVertical="12dp"
			android:text="Gestionar Pedidos"
			android:textAllCaps="false"
			android:textSize="16sp"
			android:textStyle="bold"
			app:cornerRadius="12dp"
			app:layout_constraintEnd_toEndOf="parent"
			app:layout_constraintStart_toStartOf="parent"
			app:layout_constraintTop_toBottomOf="@+id/divider"
			android:onClick="pedidoMenu"/>

	<Button
			android:id="@+id/btnMetodoPago"
			style="@style/Widget.MaterialComponents.Button.OutlinedButton"
			android:layout_width="0dp"
			android:layout_height="60dp"
			android:layout_marginStart="24dp"
			android:layout_marginTop="16dp"
			android:layout_marginEnd="24dp"
			android:elevation="2dp"
			android:fontFamily="sans-serif"
			android:letterSpacing="0.02"
			android:minHeight="60dp"
			android:paddingVertical="12dp"
			android:text="Gestionar Métodos de Pago"
			android:textAllCaps="false"
			android:textSize="16sp"
			android:textStyle="bold"
			app:cornerRadius="12dp"
			app:layout_constraintEnd_toEndOf="parent"
			app:layout_constraintStart_toStartOf="parent"
			app:layout_constraintTop_toBottomOf="@+id/btnGestionarPedidos"
			android:onClick="metodoPagoMenu"/>

	<Button
			android:id="@+id/btnDevoluciones"
			style="@style/Widget.MaterialComponents.Button.OutlinedButton"
			android:layout_width="0dp"
			android:layout_height="60dp"
			android:layout_marginStart="24dp"
			android:layout_marginTop="16dp"
			android:layout_marginEnd="24dp"
			android:elevation="2dp"
			android:fontFamily="sans-serif"
			android:letterSpacing="0.02"
			android:minHeight="60dp"
			android:paddingVertical="12dp"
			android:text="Gestionar Devoluciones"
			android:textAllCaps="false"
			android:textSize="16sp"
			android:textStyle="bold"
			app:cornerRadius="12dp"
			app:layout_constraintEnd_toEndOf="parent"
			app:layout_constraintStart_toStartOf="parent"
			app:layout_constraintTop_toBottomOf="@+id/btnMetodoPago"
			android:onClick="devolucionMenu"/>

	<Button
			android:id="@+id/btnFacturas2"
			style="@style/Widget.MaterialComponents.Button.OutlinedButton"
			android:layout_width="0dp"
			android:layout_height="60dp"
			android:layout_marginStart="24dp"
			android:layout_marginTop="16dp"
			android:layout_marginEnd="24dp"
			android:elevation="2dp"
			android:fontFamily="sans-serif"
			android:letterSpacing="0.02"
			android:minHeight="60dp"
			android:paddingVertical="12dp"
			android:text="Gestionar Facturas"
			android:textAllCaps="false"
			android:textSize="16sp"
			android:textStyle="bold"
			app:cornerRadius="12dp"
			app:layout_constraintEnd_toEndOf="parent"
			app:layout_constraintStart_toStartOf="parent"
			app:layout_constraintTop_toBottomOf="@+id/btnDevoluciones"
			android:onClick="facturaMenu"/>

	<Button
			android:id="@+id/btnDetallesFactura4"
			style="@style/Widget.MaterialComponents.Button.OutlinedButton"
			android:layout_width="0dp"
			android:layout_height="60dp"
			android:layout_marginStart="24dp"
			android:layout_marginTop="16dp"
			android:layout_marginEnd="24dp"
			android:elevation="2dp"
			android:fontFamily="sans-serif"
			android:letterSpacing="0.02"
			android:minHeight="60dp"
			android:paddingVertical="12dp"
			android:text="Gestionar Detalles de Factura"
			android:textAllCaps="false"
			android:textSize="16sp"
			android:textStyle="bold"
			app:cornerRadius="12dp"
			app:layout_constraintEnd_toEndOf="parent"
			app:layout_constraintStart_toStartOf="parent"
			app:layout_constraintTop_toBottomOf="@+id/btnFacturas2"
			android:onClick="detallefacturaMenu"/>

	<Button
			android:id="@+id/btnDetallesPedido"
			style="@style/Widget.MaterialComponents.Button.OutlinedButton"
			android:layout_width="0dp"
			android:layout_height="60dp"
			android:layout_marginStart="24dp"
			android:layout_marginTop="16dp"
			android:layout_marginEnd="24dp"
			android:layout_marginBottom="24dp"
			android:elevation="2dp"
			android:fontFamily="sans-serif"
			android:letterSpacing="0.02"
			android:minHeight="60dp"
			android:paddingVertical="12dp"
			android:text="Gestionar Detalles de Pedido"
			android:textAllCaps="false"
			android:textSize="16sp"
			android:textStyle="bold"
			app:cornerRadius="12dp"
			app:layout_constraintBottom_toBottomOf="parent"
			app:layout_constraintEnd_toEndOf="parent"
			app:layout_constraintStart_toStartOf="parent"
			app:layout_constraintTop_toBottomOf="@+id/btnDetallesFactura4"
			android:onClick="detallepedidoMenu"
			app:layout_constraintHorizontal_bias="1.0"
			app:layout_constraintVertical_bias="0.0"/>

</androidx.constraintlayout.widget.ConstraintLayout>