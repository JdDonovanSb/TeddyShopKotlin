<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
		xmlns:android="http://schemas.android.com/apk/res/android"
		xmlns:tools="http://schemas.android.com/tools"
		xmlns:app="http://schemas.android.com/apk/res-auto"
		android:id="@+id/main"
		android:layout_width="match_parent"
		android:layout_height="match_parent"
		tools:context=".Views.AdministradorActivity">

	<TextView
			android:id="@+id/textViewTitulo"
			android:layout_width="289dp"
			android:layout_height="48dp"
			android:text="Modulos de Administrador"
			android:textSize="24sp"
			app:layout_constraintTop_toTopOf="parent"
			app:layout_constraintStart_toStartOf="parent"
			app:layout_constraintEnd_toEndOf="parent" app:layout_constraintBottom_toBottomOf="parent"
			app:layout_constraintVertical_bias="0.023"/>
	<Button
			android:id="@+id/buttonPedidos"
			android:text="Administrar pedidos"
			android:layout_width="199dp"
			android:layout_height="63dp"
			android:onClick="mainPedido"
			app:layout_constraintBottom_toBottomOf="parent"
			app:layout_constraintTop_toTopOf="parent" app:layout_constraintStart_toStartOf="parent"
			app:layout_constraintEnd_toEndOf="parent" app:layout_constraintVertical_bias="0.163"
			app:layout_constraintHorizontal_bias="0.476"/>
	<Button
			android:id="@+id/btnProductos"
			android:text="Administrar productos"
			android:layout_width="198dp"
			android:layout_height="64dp"
			android:onClick="mainProducto"
			app:layout_constraintTop_toTopOf="parent"
			app:layout_constraintBottom_toBottomOf="parent" app:layout_constraintStart_toStartOf="parent"
			app:layout_constraintEnd_toEndOf="parent"
			app:layout_constraintVertical_bias="0.283" app:layout_constraintHorizontal_bias="0.474"/>
	<Button
			android:id="@+id/btnUsuarios"
			android:text="Administrar Usuarios"
			android:layout_width="198dp"
			android:layout_height="64dp"
			android:onClick="mainUsuario"
			app:layout_constraintTop_toTopOf="parent"
			app:layout_constraintBottom_toBottomOf="parent" app:layout_constraintStart_toStartOf="parent"
			app:layout_constraintEnd_toEndOf="parent"
			app:layout_constraintVertical_bias="0.4" app:layout_constraintHorizontal_bias="0.474"/>

</androidx.constraintlayout.widget.ConstraintLayout>
