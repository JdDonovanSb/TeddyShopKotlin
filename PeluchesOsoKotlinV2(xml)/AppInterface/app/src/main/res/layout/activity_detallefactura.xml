<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
		xmlns:android="http://schemas.android.com/apk/res/android"
		xmlns:tools="http://schemas.android.com/tools"
		xmlns:app="http://schemas.android.com/apk/res-auto"
		android:id="@+id/main"
		android:layout_width="match_parent"
		android:layout_height="match_parent"
		tools:context=".Views.Pedidos.DetalleFacturaActivity">

	<TextView
			android:id="@+id/textViewTitulo"
			android:layout_width="wrap_content"
			android:layout_height="wrap_content"
			android:text="Formulario Detalles Factura"
			app:layout_constraintTop_toTopOf="parent"
			app:layout_constraintStart_toStartOf="parent"
			app:layout_constraintEnd_toEndOf="parent"
			app:layout_constraintVertical_bias="0.008"/>

	<EditText
			android:id="@+id/numDetalle"
			android:layout_width="0dp"
			android:layout_height="wrap_content"
			android:hint="Número de detalle"
			android:inputType="number"
			app:layout_constraintStart_toStartOf="parent"
			app:layout_constraintEnd_toEndOf="parent"
			app:layout_constraintTop_toBottomOf="@id/textViewTitulo"
			android:layout_marginTop="16dp"/>

	<EditText
			android:id="@+id/precioDetalle"
			android:layout_width="0dp"
			android:layout_height="wrap_content"
			android:hint="Precio"
			android:inputType="numberDecimal"
			app:layout_constraintStart_toStartOf="parent"
			app:layout_constraintEnd_toEndOf="parent"
			app:layout_constraintTop_toBottomOf="@id/numDetalle"
			android:layout_marginTop="8dp"/>

	<EditText
			android:id="@+id/cantidadDetalle"
			android:layout_width="0dp"
			android:layout_height="wrap_content"
			android:hint="Cantidad"
			android:inputType="number"
			app:layout_constraintStart_toStartOf="parent"
			app:layout_constraintEnd_toEndOf="parent"
			app:layout_constraintTop_toBottomOf="@id/precioDetalle"
			android:layout_marginTop="8dp"/>

	<Button
			android:id="@+id/crearDetalleFactura"
			android:text="Crear Detalle"
			android:layout_width="159dp"
			android:layout_height="47dp"
			android:onClick="crearDetalleFactura"
			app:layout_constraintStart_toStartOf="parent"
			app:layout_constraintHorizontal_bias="0.13"
			app:layout_constraintTop_toBottomOf="@id/cantidadDetalle"
			android:layout_marginTop="16dp"/>

	<Button
			android:id="@+id/listarDetallesFactura"
			android:text="Listar Detalles"
			android:layout_width="159dp"
			android:layout_height="47dp"
			android:onClick="listarDetallesFactura"
			app:layout_constraintEnd_toEndOf="parent"
			app:layout_constraintHorizontal_bias="0.869"
			app:layout_constraintTop_toBottomOf="@id/cantidadDetalle"
			android:layout_marginTop="16dp"/>

	<TextView
			android:id="@+id/textViewListado"
			android:text="Visualización de detalles de factura"
			android:layout_width="wrap_content"
			android:layout_height="wrap_content"
			app:layout_constraintStart_toStartOf="parent"
			app:layout_constraintEnd_toEndOf="parent"
			app:layout_constraintTop_toBottomOf="@id/crearDetalleFactura"
			android:layout_marginTop="24dp"/>

	<!-- Tabla de detalles -->
	<ScrollView
			android:layout_width="0dp"
			android:layout_height="0dp"
			app:layout_constraintTop_toBottomOf="@id/textViewListado"
			app:layout_constraintStart_toStartOf="parent"
			app:layout_constraintEnd_toEndOf="parent"
			app:layout_constraintBottom_toBottomOf="parent"
			android:fillViewport="true">

		<TableLayout
				android:id="@+id/tableDetallesFactura"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:stretchColumns="*"
				android:padding="8dp">

			<TableRow
					android:layout_width="wrap_content"
					android:layout_height="54dp"
					android:background="#DDDDDD">

				<TextView
						android:layout_width="0dp"
						android:layout_height="wrap_content"
						android:layout_weight="1"
						android:text="Número"
						android:padding="8dp"
						android:textStyle="bold"/>

				<TextView
						android:layout_width="0dp"
						android:layout_height="wrap_content"
						android:layout_weight="1"
						android:text="Precio"
						android:padding="8dp"
						android:textStyle="bold"/>

				<TextView
						android:layout_width="0dp"
						android:layout_height="wrap_content"
						android:layout_weight="1"
						android:text="Cantidad"
						android:padding="8dp"
						android:textStyle="bold"/>

				<TextView
						android:layout_width="0dp"
						android:layout_height="wrap_content"
						android:layout_weight="1.5"
						android:text="Acciones"
						android:padding="8dp"
						android:textStyle="bold"/>
			</TableRow>
		</TableLayout>
	</ScrollView>

	<!-- Formulario de actualización -->
	<androidx.constraintlayout.widget.ConstraintLayout
			android:id="@+id/layoutActualizarDetalle"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:padding="16dp"
			android:visibility="gone"
			app:layout_constraintTop_toTopOf="parent"
			app:layout_constraintStart_toStartOf="parent"
			app:layout_constraintEnd_toEndOf="parent"
			android:background="@android:color/white">

		<TextView
				android:id="@+id/textViewTituloDialog"
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:text="Actualizar Detalle"
				android:textSize="18sp"
				android:textStyle="bold"
				app:layout_constraintTop_toTopOf="parent"
				app:layout_constraintStart_toStartOf="parent"
				app:layout_constraintEnd_toEndOf="parent" />

		<EditText
				android:id="@+id/editNumDetalle"
				android:layout_width="0dp"
				android:layout_height="wrap_content"
				android:hint="Número de detalle"
				android:inputType="number"
				app:layout_constraintStart_toStartOf="parent"
				app:layout_constraintEnd_toEndOf="parent"
				app:layout_constraintTop_toBottomOf="@id/textViewTituloDialog"
				android:layout_marginTop="8dp"/>

		<EditText
				android:id="@+id/editPrecioDetalle"
				android:layout_width="0dp"
				android:layout_height="wrap_content"
				android:hint="Precio"
				android:inputType="numberDecimal"
				app:layout_constraintStart_toStartOf="parent"
				app:layout_constraintEnd_toEndOf="parent"
				app:layout_constraintTop_toBottomOf="@id/editNumDetalle"
				android:layout_marginTop="8dp"/>

		<EditText
				android:id="@+id/editCantidadDetalle"
				android:layout_width="0dp"
				android:layout_height="wrap_content"
				android:hint="Cantidad"
				android:inputType="number"
				app:layout_constraintStart_toStartOf="parent"
				app:layout_constraintEnd_toEndOf="parent"
				app:layout_constraintTop_toBottomOf="@id/editPrecioDetalle"
				android:layout_marginTop="8dp"/>

		<Button
				android:id="@+id/btnActualizarDetalle"
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:text="Actualizar"
				android:onClick="actualizarDetalleFactura"
				app:layout_constraintTop_toBottomOf="@id/editCantidadDetalle"
				app:layout_constraintStart_toStartOf="parent"
				android:layout_marginTop="16dp"/>

		<Button
				android:id="@+id/btnCancelarActualizar"
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:text="Cancelar"
				app:layout_constraintTop_toBottomOf="@id/editCantidadDetalle"
				app:layout_constraintEnd_toEndOf="parent"
				android:layout_marginTop="16dp"/>

	</androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>