<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
			android:layout_width="match_parent"
			android:layout_height="match_parent">

	<LinearLayout
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:orientation="vertical"
			android:padding="16dp">

		<!-- Campo para ID del Detalle (usado en actualizar y eliminar) -->
		<EditText
				android:id="@+id/idDetalleFactura"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:hint="ID del Detalle (para actualizar o eliminar)" />

		<!-- Campo para Número de Detalle -->
		<EditText
				android:id="@+id/numDetalle"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:hint="Número de Detalle" />

		<!-- Campo para Precio -->
		<EditText
				android:id="@+id/precioDetalle"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:hint="Precio" />

		<!-- Campo para Cantidad -->
		<EditText
				android:id="@+id/cantidadDetalle"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:hint="Cantidad" />

		<!-- Botón para Crear Detalle de Factura -->
		<Button
				android:onClick="crearDetalleFactura"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:text="Crear Detalle de Factura" />

		<!-- Botón para Listar Detalles de Factura -->
		<Button
				android:onClick="listarDetallesFactura"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:text="Listar Detalles de Factura" />

		<!-- Botón para Actualizar Detalle de Factura -->
		<Button
				android:onClick="actualizarDetalleFactura"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:text="Actualizar Detalle de Factura" />

		<!-- Botón para Eliminar Detalle de Factura -->
		<Button
				android:onClick="eliminarDetalleFactura"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:text="Eliminar Detalle de Factura" />

		<!-- Área para mostrar los detalles de factura -->
		<TextView
				android:id="@+id/textViewDetallesFactura"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:text="Detalles de factura aparecerán aquí"
				android:paddingTop="16dp" />
	</LinearLayout>
</ScrollView>
