<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
		xmlns:android="http://schemas.android.com/apk/res/android"
		xmlns:app="http://schemas.android.com/apk/res-auto"
		xmlns:tools="http://schemas.android.com/tools"
		android:id="@+id/main"
		android:layout_width="match_parent"
		android:layout_height="match_parent"
		android:background="@android:color/white"
		tools:context=".Views.Usuarios.MainUsuariosActivity">

	<TextView
			android:id="@+id/textViewTituloUsuarios"
			android:layout_width="wrap_content"
			android:layout_height="wrap_content"
			android:layout_marginTop="24dp"
			android:fontFamily="sans-serif-condensed"
			android:text="Gestionar Usuarios"
			android:textSize="26sp"
			android:textStyle="bold"
			app:layout_constraintEnd_toEndOf="parent"
			app:layout_constraintStart_toStartOf="parent"
			app:layout_constraintTop_toTopOf="parent" />

	<View
			android:id="@+id/divider"
			android:layout_width="match_parent"
			android:layout_height="2dp"
			android:layout_marginTop="8dp"
			android:layout_marginHorizontal="24dp"
			android:background="#EEEEEE"
			app:layout_constraintTop_toBottomOf="@+id/textViewTituloUsuarios" />

	<Button
			android:id="@+id/btnGestionarRoles"
			style="@style/Widget.MaterialComponents.Button.OutlinedButton"
			android:layout_width="0dp"
			android:layout_height="60dp"
			android:layout_marginStart="24dp"
			android:layout_marginTop="32dp"
			android:layout_marginEnd="24dp"
			android:elevation="2dp"
			android:fontFamily="sans-serif"
			android:letterSpacing="0.02"
			android:minHeight="60dp"
			android:paddingVertical="12dp"
			android:text="Gestionar Roles"
			android:textAllCaps="false"
			android:textSize="16sp"
			android:textStyle="bold"
			app:cornerRadius="12dp"
			app:layout_constraintEnd_toEndOf="parent"
			app:layout_constraintStart_toStartOf="parent"
			app:layout_constraintTop_toBottomOf="@+id/divider"
			android:onClick="rolMenu"/>

	<Button
			android:id="@+id/btnCliente"
			style="@style/Widget.MaterialComponents.Button.OutlinedButton"
			android:layout_width="0dp"
			android:layout_height="60dp"
			android:layout_marginStart="24dp"
			android:layout_marginTop="16dp"
			android:layout_marginEnd="24dp"
			android:elevation="2dp"
			android:fontFamily="sans-serif"
			android:letterSpacing="0.02"
			android:minHeight="60dp"
			android:paddingVertical="12dp"
			android:text="Gestionar Cliente"
			android:textAllCaps="false"
			android:textSize="16sp"
			android:textStyle="bold"
			app:cornerRadius="12dp"
			app:layout_constraintEnd_toEndOf="parent"
			app:layout_constraintStart_toStartOf="parent"
			app:layout_constraintTop_toBottomOf="@+id/btnGestionarRoles"
			android:onClick="clienteMenu"/>

	<Button
			android:id="@+id/btnEmpleado"
			style="@style/Widget.MaterialComponents.Button.OutlinedButton"
			android:layout_width="0dp"
			android:layout_height="60dp"
			android:layout_marginStart="24dp"
			android:layout_marginTop="16dp"
			android:layout_marginEnd="24dp"
			android:elevation="2dp"
			android:fontFamily="sans-serif"
			android:letterSpacing="0.02"
			android:minHeight="60dp"
			android:paddingVertical="12dp"
			android:text="Gestionar Empleados"
			android:textAllCaps="false"
			android:textSize="16sp"
			android:textStyle="bold"
			app:cornerRadius="12dp"
			app:layout_constraintEnd_toEndOf="parent"
			app:layout_constraintStart_toStartOf="parent"
			app:layout_constraintTop_toBottomOf="@+id/btnCliente"
			android:onClick="empleadoMenu"/>

	<Button
			android:id="@+id/btnUsuario"
			style="@style/Widget.MaterialComponents.Button.OutlinedButton"
			android:layout_width="0dp"
			android:layout_height="60dp"
			android:layout_marginStart="24dp"
			android:layout_marginTop="16dp"
			android:layout_marginEnd="24dp"
			android:elevation="2dp"
			android:fontFamily="sans-serif"
			android:letterSpacing="0.02"
			android:minHeight="60dp"
			android:paddingVertical="12dp"
			android:text="Gestionar Usuarios"
			android:textAllCaps="false"
			android:textSize="16sp"
			android:textStyle="bold"
			app:cornerRadius="12dp"
			app:layout_constraintEnd_toEndOf="parent"
			app:layout_constraintStart_toStartOf="parent"
			app:layout_constraintTop_toBottomOf="@+id/btnEmpleado"
			android:onClick="usuarioMenu"/>

	<Button
			android:id="@+id/btnCompañia"
			style="@style/Widget.MaterialComponents.Button.OutlinedButton"
			android:layout_width="0dp"
			android:layout_height="60dp"
			android:layout_marginStart="24dp"
			android:layout_marginTop="16dp"
			android:layout_marginEnd="24dp"
			android:layout_marginBottom="24dp"
			android:elevation="2dp"
			android:fontFamily="sans-serif"
			android:letterSpacing="0.02"
			android:minHeight="60dp"
			android:paddingVertical="12dp"
			android:text="Gestionar Compañía"
			android:textAllCaps="false"
			android:textSize="16sp"
			android:textStyle="bold"
			app:cornerRadius="12dp"
			app:layout_constraintBottom_toBottomOf="parent"
			app:layout_constraintEnd_toEndOf="parent"
			app:layout_constraintStart_toStartOf="parent"
			app:layout_constraintTop_toBottomOf="@+id/btnUsuario"
			android:onClick="CompañiaMenu"
			app:layout_constraintHorizontal_bias="1.0"
			app:layout_constraintVertical_bias="0.0"/>

</androidx.constraintlayout.widget.ConstraintLayout>