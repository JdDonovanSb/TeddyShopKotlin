<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
		xmlns:android="http://schemas.android.com/apk/res/android"
		xmlns:tools="http://schemas.android.com/tools"
		xmlns:app="http://schemas.android.com/apk/res-auto"
		android:id="@+id/main"
		android:layout_width="match_parent"
		android:layout_height="match_parent"
		tools:context=".Views.Usuarios.MainUsuariosActivity">

	<TextView
			android:id="@+id/textViewTituloUsuarios"
			android:layout_width="220dp"
			android:layout_height="48dp"
			android:text="Gestionar Usuarios"
			android:textSize="24sp"
			app:layout_constraintTop_toTopOf="parent"
			app:layout_constraintStart_toStartOf="parent"
			app:layout_constraintEnd_toEndOf="parent" app:layout_constraintBottom_toBottomOf="parent"
			app:layout_constraintVertical_bias="0.023"/>
	<Button
            android:id="@+id/btnGestionarRoles"
            android:text="Gestionar Roles"
            android:layout_width="199dp"
            android:layout_height="63dp"
            android:onClick="rolMenu"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintTop_toTopOf="parent" app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" app:layout_constraintVertical_bias="0.163"
            app:layout_constraintHorizontal_bias="0.476"/>
	<Button
			android:id="@+id/btnCliente"
			android:text="Gestionar Cliente"
			android:layout_width="198dp"
			android:layout_height="64dp"
			android:onClick="clienteMenu"
			app:layout_constraintTop_toTopOf="parent"
			app:layout_constraintBottom_toBottomOf="parent" app:layout_constraintStart_toStartOf="parent"
			app:layout_constraintEnd_toEndOf="parent"
			app:layout_constraintVertical_bias="0.283" app:layout_constraintHorizontal_bias="0.474"/>

	<Button
			android:id="@+id/btnEmpleado"
			android:text="Gestionar Empleados"
			android:layout_width="198dp"
			android:layout_height="64dp"
			android:onClick="empleadoMenu"
			app:layout_constraintTop_toTopOf="parent"
			app:layout_constraintBottom_toBottomOf="parent"
			app:layout_constraintStart_toStartOf="parent"
			app:layout_constraintEnd_toEndOf="parent"
			app:layout_constraintVertical_bias="0.406"
			app:layout_constraintHorizontal_bias="0.497"/>

	<Button
			android:id="@+id/btnUsuario"
			android:text="Gestionar Usuarios"
			android:layout_width="198dp"
			android:layout_height="64dp"
			android:onClick="usuarioMenu"
			app:layout_constraintTop_toTopOf="parent"
			app:layout_constraintBottom_toBottomOf="parent"
			app:layout_constraintStart_toStartOf="parent"
			app:layout_constraintEnd_toEndOf="parent"
			app:layout_constraintVertical_bias="0.538"
			app:layout_constraintHorizontal_bias="0.474"/>

</androidx.constraintlayout.widget.ConstraintLayout>
